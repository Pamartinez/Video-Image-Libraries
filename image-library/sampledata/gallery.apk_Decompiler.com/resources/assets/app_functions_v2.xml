    <appfunction>
        <id>com.samsung.android.gallery.crossapp.function.SearchFunctions#findPhotos</id>
        <enabledByDefault>true</enabledByDefault>
        <description>Searches for images and videos based on a user's text query.
 This function is designed to parse the user's request for specific details like dates, time ranges, and locations (city and country) to perform a refined search.
 For optimal results, you should extract these details into the corresponding optional fields (startTime, endTime, city, country, countryCode) whenever they are mentioned, in addition to creating a detailed queryString.</description>
        <parameters>
            <dataTypeMetadata>
                <id>unused</id>
                <isNullable>false</isNullable>
                <type>8</type>
            </dataTypeMetadata>
            <id>unused</id>
            <isRequired>true</isRequired>
            <name>queryString</name>
            <description>(Required) Contains only the part of the user's utterance or input relevant to photo search. This should contain only the descriptive part of the user's request that relates to the photos or videos being searched for, including modifiers like location, time, subjects, and other qualifying attributes. Command words like "find", "show", "get" should be excluded, keeping only the content description. Examples: - "photos I took in Paris last year" (from "Find photos I took in Paris last year") - "pictures from my trip to Tokyo in December" (from "Show me pictures from my trip to Tokyo in December") - "videos of my dog playing in the park yesterday" (from "Videos of my dog playing in the park yesterday") - "sunset photos from my vacation in Hawaii" (from "Find sunset photos from my vacation in Hawaii")</description>
        </parameters>
        <parameters>
            <dataTypeMetadata>
                <id>unused</id>
                <isNullable>true</isNullable>
                <type>7</type>
            </dataTypeMetadata>
            <id>unused</id>
            <isRequired>false</isRequired>
            <name>maxCount</name>
            <description>(Optional) The maximum number of results requested.</description>
        </parameters>
        <response>
            <id>unused</id>
            <valueType>
                <dataTypeReference>com.samsung.android.gallery.crossapp.function.FindPhotosResponse</dataTypeReference>
                <id>unused</id>
                <isNullable>false</isNullable>
                <type>11</type>
            </valueType>
            <description>FindPhotosResponse The found content's response with media items and resources (MAX = 50) </description>
        </response>
        <functionId>com.samsung.android.gallery.crossapp.function.SearchFunctions#findPhotos</functionId>
    </appfunction>
