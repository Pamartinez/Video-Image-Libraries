<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:foreground="@drawable/thumbnail_selector" android:contentDescription="@string/speak_button" android:importantForAccessibility="yes">
    <FrameLayout android:id="@+id/item_container" android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:foreground="@drawable/thumbnail_border" style="@style/ThumbnailStyle"/>
