            <ViewStub android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/storage_favorite_slot1_ViewStub" android:layout="@layout/storage_favorite_slot1" android:inflatedId="@+id/storage_favorite_slot1" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <ViewStub android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/storage_favorite_slot2_ViewStub" android:layout="@layout/storage_favorite_slot2" android:inflatedId="@+id/storage_favorite_slot2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingEnd="27dp"/>
