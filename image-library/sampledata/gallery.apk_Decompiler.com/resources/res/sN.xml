<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="wrap_content" android:layout_height="wrap_content">
    <FrameLayout android:id="@+id/item_layout" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <ImageView android:id="@+id/clipboard_list_item_thumbnail" android:background="@drawable/clipboard_thumbnail_stroke" android:focusable="false" android:layout_width="@dimen/clipboard_list_item_thumb_width_sp" android:layout_height="@dimen/clipboard_list_item_thumb_height_sp" android:layout_marginTop="@dimen/clipboard_list_item_delete_icon_outside_area_of_thumb" android:cropToPadding="true" android:contentDescription="@null" android:layout_marginEnd="@dimen/clipboard_list_item_delete_icon_outside_area_of_thumb"/>
        <ImageView android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/clipboard_list_remove_icon" android:focusable="false" android:layout_width="@dimen/clipboard_list_item_delete_icon_width" android:layout_height="@dimen/clipboard_list_item_delete_icon_height" android:src="@drawable/gallery_picker_ic_delete_with_bg" android:contentDescription="@string/remove"/>
        <LinearLayout android:gravity="center_vertical" android:layout_gravity="bottom|left|center_vertical|center_horizontal|center|start" android:id="@+id/content_type_container" android:background="@drawable/thumbnail_content_type_container" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="@dimen/content_type_container_height" android:layout_marginBottom="@dimen/content_type_container_margin" android:importantForAccessibility="noHideDescendants" android:layout_marginStart="@dimen/content_type_container_margin">
            <ImageView android:id="@+id/content_type_icon" android:background="@drawable/gallery_ic_thumbnail_video" android:focusable="false" android:layout_width="@dimen/content_type_icon_height" android:layout_height="@dimen/content_type_icon_height" android:tint="@color/white_color" android:contentDescription="@null" android:layout_marginStart="@dimen/content_type_icon_side_margin" android:layout_marginEnd="@dimen/content_type_icon_side_margin"/>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
