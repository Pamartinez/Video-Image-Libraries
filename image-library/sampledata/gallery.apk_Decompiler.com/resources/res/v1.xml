<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:expanded="false" style="@style/AppBarLayoutStyle">
        <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" style="@style/CollapsingToolBarStyle">
            <include layout="@layout/floating_toolbar_dummy_view"/>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
    <LinearLayout android:orientation="vertical" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <ViewStub android:id="@+id/empty_view" android:layout="@layout/fragment_mtp_empty_view_stub" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true"/>
            <com.samsung.android.gallery.widget.listview.GalleryListView android:id="@+id/my_recycler_view" android:paddingTop="4dp" android:layout_width="match_parent" android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>
    <include layout="@layout/floating_toolbar_layout"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
