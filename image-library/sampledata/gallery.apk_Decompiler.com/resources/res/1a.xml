<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/clipboard_layout" android:visibility="visible" android:layout_width="match_parent" android:layout_height="wrap_content">
    <RelativeLayout android:id="@+id/selected_layout" android:background="@color/default_background" android:visibility="visible" android:layout_width="match_parent" android:layout_height="@dimen/clipboard_selected_layout_height" android:layout_marginBottom="@dimen/clipboard_selected_layout_margin_bottom">
        <TextView android:textSize="@dimen/picker_clipboard_no_item_text_size" android:textColor="@color/noitem_text_color_for_grace" android:ellipsize="end" android:gravity="center" android:layout_gravity="center" android:id="@+id/no_item_selected" android:visibility="visible" android:layout_width="match_parent" android:layout_height="match_parent" android:text="@string/no_selection_items" android:maxLines="2" android:textAlignment="center" android:paddingHorizontal="45dp" style="@style/OneUiRobotoRegular"/>
        <androidx.recyclerview.widget.RecyclerView android:scrollbarStyle="outsideOverlay" android:id="@+id/recycler_list" android:paddingTop="@dimen/clipboard_layout_top_padding" android:focusable="true" android:focusableInTouchMode="true" android:visibility="gone" android:scrollbars="horizontal" android:layout_width="match_parent" android:layout_height="match_parent"/>
    </RelativeLayout>
    <RelativeLayout android:id="@+id/toggle_layout" android:background="@color/default_background" android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:id="@+id/toggle_line" android:background="@color/search_count_header_background_line_color" android:layout_width="match_parent" android:layout_height="@dimen/clipboard_toggle_layout_background_line" android:layout_centerInParent="true"/>
        <ImageView android:gravity="center" android:id="@+id/toggle" android:background="@color/default_background" android:visibility="visible" android:layout_width="@dimen/clipboard_toggle_image_view_width" android:layout_height="@dimen/clipboard_toggle_image_view_height" android:src="@drawable/clipboard_closed" android:tint="@color/search_category_arrow_color" android:layout_centerInParent="true" android:rotation="180"/>
    </RelativeLayout>
</LinearLayout>
