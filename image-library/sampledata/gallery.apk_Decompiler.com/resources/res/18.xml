<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/video_controller_view" android:background="@drawable/viewer_flip_cover_button_bg" android:layout_width="wrap_content" android:layout_height="@dimen/play_button_view_height">
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/flip_cover_video_play_control_view" android:focusable="true" android:clickable="true" android:layout_width="wrap_content" android:layout_height="match_parent" android:foreground="@drawable/viewer_recoil_button_ripple" android:paddingStart="8dp" android:paddingEnd="8dp" android:stateListAnimator="?attr/seslSmallTouchAnimator">
        <ImageButton android:id="@+id/play_pause_button" android:background="@null" android:focusable="false" android:clickable="false" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/gallery_ic_detail_play" android:scaleType="fitCenter" android:tint="@color/play_button_view_text_color" android:contentDescription="@null" android:importantForAccessibility="no"/>
        <TextView android:textSize="13dp" android:textColor="@color/play_button_view_text_color" android:id="@+id/text_elapsed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:layout_marginStart="4dp" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="12dp" android:textColor="@color/play_button_view_slash_color" android:id="@+id/text_duration_slash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="13dp" android:textColor="@color/play_button_view_duration_text_color" android:id="@+id/text_duration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" style="@style/OneUiRobotoRegular"/>
    </LinearLayout>
    <View android:background="#26ffffff" android:layout_width="1dp" android:layout_height="19dp"/>
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/flip_cover_video_sound_control_view" android:layout_width="wrap_content" android:layout_height="match_parent" android:paddingStart="7dp" android:paddingEnd="11dp">
        <ImageView android:id="@+id/flip_cover_play_audio_icon" android:layout_width="24dp" android:layout_height="24dp" android:foreground="@drawable/recoil_oval_shape" android:src="@drawable/gallery_ic_detail_sound_off" android:contentDescription="@string/toggle_audio" android:alpha="0.4" android:tooltipText="@string/toggle_audio"/>
    </LinearLayout>
</LinearLayout>
