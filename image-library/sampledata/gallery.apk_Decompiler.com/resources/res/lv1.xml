<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center" android:id="@+id/touchable_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/search_face_icon_margin_top" android:layout_marginBottom="@dimen/search_face_margin_bottom" android:foreground="@drawable/recoil_ripple_rect" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:paddingHorizontal="@dimen/search_header_title_side_padding">
            <LinearLayout android:id="@+id/thumbnail_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
                <LinearLayout android:gravity="center" android:layout_gravity="bottom" android:id="@+id/prev_thumbnail_layout" android:background="@color/search_prev_face_stroke_color" android:visibility="gone" android:layout_width="@dimen/search_prev_face_layout_size" android:layout_height="@dimen/search_prev_face_layout_size" android:layout_marginEnd="@dimen/search_prev_face_layout_end_margin">
                    <ImageView android:id="@+id/prev_thumbnail" android:background="@color/thumbnail_icon_background" android:layout_width="@dimen/search_prev_face_icon_size" android:layout_height="@dimen/search_prev_face_icon_size" android:scaleType="centerCrop" android:contentDescription="@null"/>
                </LinearLayout>
                <RelativeLayout android:gravity="center" android:id="@+id/cur_thumbnail_layout" android:background="@color/search_prev_face_stroke_color" android:layout_width="@dimen/search_face_layout_size" android:layout_height="@dimen/search_face_layout_size" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0">
                    <ImageView android:id="@+id/creature_header_thumbnail" android:background="@drawable/creature_header_thumbnail_background" android:layout_width="@dimen/search_face_icon_size" android:layout_height="@dimen/search_face_icon_size" android:scaleType="centerCrop" android:contentDescription="@null" android:outlineProvider="background"/>
                    <ImageView android:id="@+id/thumbnail_for_flip_prev" android:background="@color/thumbnail_icon_background" android:visibility="gone" android:layout_width="@dimen/search_face_icon_size" android:layout_height="@dimen/search_face_icon_size" android:scaleType="centerCrop" android:contentDescription="@null"/>
                    <ImageView android:id="@+id/thumbnail_for_flip_next" android:background="@color/thumbnail_icon_background" android:visibility="gone" android:layout_width="@dimen/search_face_icon_size" android:layout_height="@dimen/search_face_icon_size" android:scaleType="centerCrop" android:contentDescription="@null"/>
                </RelativeLayout>
            </LinearLayout>
            <TextView android:textSize="@dimen/search_face_text_size" android:textColor="@color/search_category_item_title_color" android:ellipsize="end" android:id="@+id/title" android:paddingTop="@dimen/search_header_title_top_padding" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="@dimen/search_header_title_max_width" android:maxLines="2" android:textIsSelectable="false" android:textAlignment="center" app:layout_constraintBottom_toTopOf="@+id/relationshipType" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/thumbnail_layout" style="@style/OneUiRobotoSemiBold"/>
            <LinearLayout android:orientation="vertical" android:id="@+id/edit_title_layout" android:paddingTop="@dimen/search_header_title_top_padding_no_name" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintBottom_toTopOf="@+id/relationshipType" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/thumbnail_layout">
                <ImageView android:layout_gravity="center" android:id="@+id/editArrow" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/gallery_tag_people_bubble_picker" android:scaleType="center" android:tint="@color/search_people_header_background_color" android:contentDescription="@null" android:tintMode="multiply"/>
                <TextView android:textSize="@dimen/search_face_text_size" android:textColor="@color/search_people_header_text_color" android:gravity="center" android:layout_gravity="center" android:id="@+id/editTitle" android:background="@drawable/search_people_tag_edit_title_shape" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="@dimen/search_face_no_name_bubble_height" android:text="@string/add_name" android:contentDescription="@string/untagged_face" android:textIsSelectable="false" android:paddingHorizontal="@dimen/search_face_no_name_bubble_side_padding" style="@style/OneUiRobotoSemiBold"/>
                <TextView android:textSize="@dimen/search_face_description_text_size" android:textColor="@color/search_creature_header_description_text_color" android:gravity="center" android:layout_gravity="center" android:id="@+id/editTitleDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/search_face_no_name_description_margin_top" android:text="@string/names_help_you_find_people_in_searches" android:textIsSelectable="false" style="@style/OneUiRobotoRegular"/>
            </LinearLayout>
            <TextView android:textSize="@dimen/search_face_relationship_text_size" android:textColor="@color/search_category_item_count_color" android:ellipsize="end" android:id="@+id/relationshipType" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:paddingStart="@dimen/search_header_title_side_padding" android:paddingEnd="@dimen/search_header_title_side_padding" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" style="@style/OneUiRobotoRegular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <FrameLayout android:id="@+id/sub_touchable_view" android:layout_width="match_parent" android:layout_height="wrap_content">
            <include android:id="@+id/face_cluster_tipcard_Header" android:visibility="gone" layout="@layout/face_cluster_tip_card_header"/>
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="14dp" android:textColor="@color/face_merge_text_color" android:layout_gravity="center" android:id="@+id/face_cluster_merge_title" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="@string/face_cluster_same_or_different_person" android:textIsSelectable="false" android:layout_marginHorizontal="24dp" style="@style/OneUiRobotoRegular"/>
                <com.google.android.material.bottomnavigation.BottomNavigationView android:layout_gravity="bottom" android:id="@+id/edit_bottom_navigation" android:background="@color/default_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" app:itemTextColor="@color/gallery_search_header_view_title_color" app:menu="@menu/menu_bottom_search_people" style="@style/BottomNavigationViewStyle.Text"/>
            </LinearLayout>
        </FrameLayout>
        <include layout="@layout/search_count_header_text"/>
    </LinearLayout>
</RelativeLayout>
