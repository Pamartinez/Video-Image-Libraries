<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_gravity="center_horizontal" android:orientation="vertical" android:id="@+id/recycler_view_item" android:focusable="true" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="@dimen/list_item_grid_size" android:layout_height="wrap_content">
    <RelativeLayout android:id="@+id/frame_view" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.samsung.android.gallery.widget.PinchBlurImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content" app:aspect_ratio="1.18"/>
        <RelativeLayout android:id="@+id/album_deco" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_alignTop="@+id/thumbnail" android:layout_alignBottom="@+id/thumbnail" android:layout_alignStart="@+id/thumbnail" android:layout_alignEnd="@+id/thumbnail">
            <FrameLayout android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_above="@+id/title_container">
                <ViewStub android:layout_gravity="center" android:id="@+id/emptyAlbumViewStub" android:layout="@layout/empty_album_view_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <LinearLayout android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/album_type_layout_margin_top_grid" android:layout_marginEnd="@dimen/album_type_layout_margin_end_grid">
                    <ViewStub android:id="@+id/album_type_stub" android:layout="@layout/stub_album_type" android:layout_width="@dimen/album_type_icon_size" android:layout_height="@dimen/album_type_icon_size"/>
                    <ImageView android:id="@+id/album_expiry_notice_icon" android:background="@drawable/gallery_ic_error_notice_badge" android:visibility="gone" android:layout_width="@dimen/sharing_view_grid_expiry_size" android:layout_height="@dimen/sharing_view_grid_expiry_size"/>
                </LinearLayout>
            </FrameLayout>
            <LinearLayout android:orientation="vertical" android:id="@+id/title_container" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/album_grid_title_container_bottom_margin" android:layout_alignParentBottom="true" android:layout_marginHorizontal="@dimen/album_grid_text_margin">
                <RelativeLayout android:gravity="center_horizontal" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/album_grid_title_top_margin" android:layout_marginBottom="@dimen/album_grid_title_bottom_margin">
                    <com.samsung.android.gallery.widget.GalleryTextView android:textSize="@dimen/album_grid_title_text_size" android:textColor="@color/one_ui_blur_album_title_text_color" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:layout_marginEnd="@dimen/new_badge_dot_size" style="@style/OneUiRobotoRegular"/>
                    <ImageView android:id="@+id/newLabel" android:visibility="gone" android:layout_marginStart="@dimen/new_badge_dot_minus_margin" android:layout_toEndOf="@+id/title" style="@style/NewDotStyle"/>
                </RelativeLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/subtitle_container" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:textSize="@dimen/sharing_view_grid_sub_title_size" android:textColor="@color/one_ui_blur_album_sub_title_text_color" android:id="@+id/count" android:padding="0dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/OneUiRobotoRegular"/>
                    <ImageView android:layout_gravity="center" android:id="@+id/subtitle_dot" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/shared_album_sub_title_dot" android:layout_marginHorizontal="@dimen/sharing_view_sub_title_gap"/>
                    <TextView android:textSize="@dimen/sharing_view_grid_sub_title_size" android:textColor="@color/one_ui_blur_album_sub_title_text_color" android:ellipsize="end" android:id="@+id/member_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" style="@style/OneUiRobotoRegular"/>
                    <TextView android:textSize="13dp" android:textColor="@color/one_ui_blur_album_sub_title_text_color" android:ellipsize="end" android:gravity="center" android:id="@+id/subtitle" android:background="@drawable/sharing_group_information_shape" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="@dimen/shared_group_layout_min_height" android:maxLines="2" android:layout_weight="1" android:textIsSelectable="false" android:textAlignment="center" android:paddingStart="@dimen/shared_view_bg_start_end_padding" android:paddingEnd="@dimen/shared_view_bg_start_end_padding" android:layout_marginStart="@dimen/shared_owner_start_margin" style="@style/OneUiRobotoRegular"/>
                    <ImageView android:id="@+id/icon" android:visibility="gone" android:layout_width="@dimen/sharing_view_grid_crown_size" android:layout_height="@dimen/sharing_view_grid_crown_size" android:src="@drawable/sharings_crown" android:contentDescription="@string/group_creator" android:layout_marginStart="@dimen/sharing_view_sub_title_gap" android:tooltipText="@string/group_creator"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
    <ViewStub android:id="@+id/border_stub" android:layout="@layout/stub_album_border_view" android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
