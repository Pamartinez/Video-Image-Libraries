<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp"/>
            <solid android:color="@color/sharingv2_invitation_bg_color"/>
        </shape>
    </item>
    <item>
        <ripple android:color="@color/divider_location_ripple_color">
            <item android:id="@android:id/mask">
                <selector>
                    <item>
                        <shape android:shape="rectangle">
                            <solid android:color="@color/list_ripple_color"/>
                            <corners android:radius="26dp"/>
                        </shape>
                    </item>
                    <item>
                        <color android:color="@android:color/transparent"/>
                    </item>
                </selector>
            </item>
        </ripple>
    </item>
</layer-list>
