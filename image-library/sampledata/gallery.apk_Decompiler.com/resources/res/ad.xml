<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="horizontal" android:focusable="true" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="@dimen/search_floating_recommend_history_item_margin_horizontal">
    <FrameLayout android:id="@+id/thumbnail_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:importantForAccessibility="noHideDescendants" android:layout_marginVertical="@dimen/search_floating_recommend_history_item_margin_vertical">
        <com.samsung.android.gallery.widget.SquareImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:focusable="false" android:clickable="false" android:layout_width="@dimen/search_floating_recommend_history_thumbnail_size" android:layout_height="@dimen/search_floating_recommend_history_thumbnail_size" android:layout_marginEnd="3dp" app:aspect_base_height="true"/>
        <FrameLayout android:layout_gravity="bottom|right|center_vertical|center_horizontal|center|end" android:id="@+id/thumbnail_circle_icon_container" android:background="@drawable/floating_history_type_icon_background" android:visibility="gone" android:layout_width="@dimen/search_floating_recommend_history_type_circle_size" android:layout_height="@dimen/search_floating_recommend_history_type_circle_size" android:contentDescription="@null" android:clipToOutline="true">
            <ImageView android:layout_gravity="center" android:id="@+id/circle_thumb" android:visibility="gone" android:layout_width="@dimen/search_floating_recommend_history_type_circle_size" android:layout_height="@dimen/search_floating_recommend_history_type_circle_size" android:contentDescription="@null" android:clipToOutline="true"/>
            <ImageView android:layout_gravity="center" android:id="@+id/type" android:visibility="gone" android:layout_width="@dimen/search_floating_recommend_history_type_size" android:layout_height="@dimen/search_floating_recommend_history_type_size" android:contentDescription="@null"/>
        </FrameLayout>
    </FrameLayout>
    <TextView android:textSize="17dp" android:textColor="@color/bottom_search_toolbar_floating_items_color" android:ellipsize="end" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/title" android:layout_width="0dp" android:layout_height="match_parent" android:maxLines="3" android:layout_weight="1" android:textAlignment="viewStart" android:layout_marginStart="12dp" style="@style/OneUiRobotoRegular"/>
    <ImageView android:layout_gravity="right|center_vertical|center_horizontal|center|end" android:id="@+id/delete_button" android:background="@drawable/recoil_button_ripple" android:padding="@dimen/search_floating_recommend_history_delete_button_padding" android:focusable="true" android:clickable="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/gallery_ic_search_button_close" android:contentDescription="@string/delete"/>
</LinearLayout>
