<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center_horizontal" android:layout_gravity="center_horizontal" android:id="@+id/pdc_recommend_view" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="12dp">
    <com.samsung.android.gallery.widget.RoundedFrameLayout android:layout_gravity="center_horizontal" android:orientation="vertical" android:id="@+id/content" android:paddingTop="23dp" android:paddingBottom="20dp" android:clipToPadding="false" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <ImageView android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/close_btn" android:background="@drawable/recoil_button_ripple" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginTop="-12dp" android:src="@drawable/tw_card_icon_close_mtrl" android:alpha="0.4" android:layout_marginEnd="12dp" android:stateListAnimator="?attr/seslSmallTouchAnimator"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/recommend_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:text=" " android:layout_weight="1" android:paddingStart="@dimen/tip_card_text_layout_padding_start" android:paddingEnd="@dimen/tip_card_text_layout_padding_end" android:textFontWeight="@integer/font_weight_600" style="@style/TipCardTitleStyle"/>
            <TextView android:textSize="12dp" android:id="@+id/pdc_suggest_matched" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/suggested_matches" android:paddingStart="@dimen/tip_card_text_layout_padding_start" android:paddingEnd="@dimen/tip_card_text_layout_padding_end" android:textFontWeight="@integer/font_weight_400" style="@style/OneUiRobotoRegular"/>
            <FrameLayout android:id="@+id/pdc_recommend_list_parent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp">
                <TextView android:layout_gravity="center" android:id="@+id/no_item_view" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/empty_set_description_no_pictures_and_videos" style="@style/NoItemDescriptionStyle"/>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/pdc_recommend_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:overScrollMode="never"/>
            </FrameLayout>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:paddingStart="@dimen/tip_card_text_layout_padding_start" android:paddingEnd="@dimen/tip_card_text_layout_padding_end">
