                <View android:layout_gravity="center_vertical" android:id="@+id/divider" android:background="@color/search_card_divider_color" android:layout_width="1dp" android:layout_height="16dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toStartOf="@+id/apply_btn" app:layout_constraintStart_toEndOf="@+id/show_full_list_btn" app:layout_constraintTop_toTopOf="0" app:layout_constraintVertical_bias="0.6"/>
