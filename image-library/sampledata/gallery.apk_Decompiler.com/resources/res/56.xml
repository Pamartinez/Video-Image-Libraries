<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:background="@color/default_background" android:paddingBottom="@dimen/tip_card_padding_bottom" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="@dimen/tip_card_padding_start" android:paddingEnd="@dimen/tip_card_padding_end">
    <com.samsung.android.gallery.widget.RoundedRelativeLayout android:id="@+id/tip_card_layout" android:background="@color/search_tag_me_tip_card_background" android:paddingBottom="@dimen/tip_card_layout_padding_bottom" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" app:cornerRadius="15dp">
        <LinearLayout android:orientation="vertical" android:background="@color/search_tag_me_tip_card_background" android:paddingTop="21dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <FrameLayout android:layout_gravity="center" android:id="@+id/thumbnail_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layoutDirection="ltr">
                <LinearLayout android:layout_gravity="bottom" android:id="@+id/main_thumbnail_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="45dp">
                    <ImageView android:id="@+id/main_thumbnail" android:background="@drawable/creature_header_thumbnail_background" android:visibility="visible" android:layout_width="@dimen/search_face_layout_size" android:layout_height="@dimen/search_face_layout_size" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_centerInParent="true" android:contentDescription="@null" android:outlineProvider="background"/>
                </LinearLayout>
                <LinearLayout android:layout_gravity="bottom" android:id="@+id/suggestion_thumbnail_layout" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <LinearLayout android:gravity="center" android:background="@drawable/creature_merge_header_thumbnail_background" android:layout_width="@dimen/search_merge_suggestion_face_layout_size" android:layout_height="@dimen/search_merge_suggestion_face_layout_size" android:contentDescription="@null" android:outlineProvider="background">
                        <ImageView android:id="@+id/suggestion_thumbnail" android:background="@drawable/creature_header_thumbnail_background" android:visibility="visible" android:layout_width="@dimen/search_merge_suggestion_face_size" android:layout_height="@dimen/search_merge_suggestion_face_size" android:scaleType="centerCrop" android:adjustViewBounds="true" android:contentDescription="@null"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="14dp" android:textColor="@color/face_merge_text_color" android:layout_gravity="center" android:id="@+id/face_cluster_merge_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/face_cluster_same_or_different_person" android:textIsSelectable="false" android:layout_marginHorizontal="24dp" style="@style/OneUiRobotoRegular"/>
                <TextView android:textSize="14dp" android:textColor="@color/face_merge_text_color" android:layout_gravity="center" android:id="@+id/face_cluster_merge_title2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="@string/face_cluster_improve_your_search_results" android:textIsSelectable="false" android:layout_marginHorizontal="24dp" style="@style/OneUiRobotoRegular"/>
                <com.google.android.material.bottomnavigation.BottomNavigationView android:layout_gravity="bottom" android:id="@+id/edit_bottom_navigation" android:background="@color/search_tag_me_tip_card_background" android:layout_width="match_parent" android:layout_height="wrap_content" app:itemTextColor="@color/gallery_search_header_view_title_color" app:menu="@menu/menu_bottom_search_face_merge" style="@style/BottomNavigationViewStyle.Text"/>
            </LinearLayout>
        </LinearLayout>
        <TextView android:textSize="14dp" android:textColor="@color/face_merge_text_color" android:layout_gravity="center" android:id="@+id/process_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:layout_alignParentTop="true" android:textIsSelectable="false" android:layout_marginEnd="15dp" android:layout_alignParentEnd="true" style="@style/OneUiRobotoRegular"/>
    </com.samsung.android.gallery.widget.RoundedRelativeLayout>
</LinearLayout>
