<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="horizontal" android:id="@+id/hover_preview_item_layout" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="@dimen/hovering_image_gap">
    <com.samsung.android.gallery.widget.videoview.mediaplayer.MediaPlayerViewCompat android:id="@+id/media_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:importantForAccessibility="no" app:disable_audio_focus="true"/>
    <ImageView android:id="@+id/hover_preview_image" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:contentDescription="@null"/>
    <ImageView android:layout_gravity="center" android:id="@+id/hover_preview_icon" android:focusable="false" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@null"/>
    <LinearLayout android:layout_gravity="end" android:orientation="horizontal" android:id="@+id/hover_preview_menu" android:background="@drawable/hover_preview_actionbar_border" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="@dimen/hovering_actionbar_height" android:layout_marginTop="@dimen/hovering_actionbar_margin_top" android:paddingStart="@dimen/hovering_actionbar_padding" android:paddingEnd="@dimen/hovering_actionbar_padding" android:layout_marginEnd="@dimen/hovering_actionbar_margin_end">
        <ImageButton android:layout_gravity="center_vertical" android:id="@+id/hover_preview_menu_share" android:background="@drawable/hover_preview_menu_ripple" android:visibility="gone" android:clickable="true" android:layout_width="@dimen/hovering_actionbar_button_size" android:layout_height="@dimen/hovering_actionbar_button_size" android:src="@drawable/spen_basic_share_mtrl" android:tint="@color/hovering_actionbar_button_color" android:contentDescription="@string/share_short" android:layout_marginEnd="@dimen/hovering_actionbar_button_gap"/>
        <ImageButton android:layout_gravity="center_vertical" android:id="@+id/hover_preview_menu_delete" android:background="@drawable/hover_preview_menu_ripple" android:visibility="gone" android:clickable="true" android:layout_width="@dimen/hovering_actionbar_button_size" android:layout_height="@dimen/hovering_actionbar_button_size" android:src="@drawable/spen_basic_delete_mtrl" android:tint="@color/hovering_actionbar_button_color" android:contentDescription="@string/delete"/>
    </LinearLayout>
</FrameLayout>
