<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:layout_width="match_parent" android:layout_height="wrap_content">
    <com.samsung.android.gallery.widget.RoundedRelativeLayout android:id="@+id/tip_card_layout" android:background="@color/update_app_card_view_bg_color" android:paddingTop="@dimen/mx_albums_header_view_tip_card_paddings" android:paddingBottom="@dimen/mx_albums_header_view_tip_card_padding_bottom" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingStart="@dimen/mx_albums_header_view_tip_card_paddings" android:paddingEnd="@dimen/mx_albums_header_view_tip_card_paddings">
        <RelativeLayout android:id="@+id/invitation_icon" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ImageView android:id="@+id/invitation_icon_view" android:background="@drawable/sharingv2_invitation_icon_bg" android:focusable="false" android:visibility="visible" android:clickable="false" android:layout_width="@dimen/invitation_host_icon_size" android:layout_height="@dimen/invitation_host_icon_size" android:scaleType="fitCenter" android:cropToPadding="true"/>
        </RelativeLayout>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toRightOf="@+id/invitation_icon" android:layout_marginStart="@dimen/shared_photo_cover_layout_start_margin">
            <TextView android:textSize="@dimen/shared_view_title_font_size" android:textColor="@color/sharingv2_invitation_title_text_color" android:id="@+id/host" style="@style/MxAlbumInvitationTextStyle"/>
            <TextView android:textSize="@dimen/shared_view_group_font_size" android:textColor="@color/sharingv2_invitation_title_text_color" android:id="@+id/title" style="@style/MxAlbumInvitationTextStyle"/>
            <TextView android:textSize="@dimen/shared_view_group_font_size" android:textColor="@color/sharingv2_invitation_date_text_color" android:id="@+id/expire_date" android:layout_marginTop="@dimen/mx_albums_header_view_tip_card_title_vertical_gap" style="@style/MxAlbumInvitationTextStyle"/>
            <LinearLayout android:gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/mx_albums_header_view_tip_card_button_vertical_gap">
                <TextView android:id="@+id/decline" android:text="@string/join_decline" android:layout_marginEnd="@dimen/sharingv2_invitation_decline_button_margin_end" style="@style/MxAlbumInvitationButtonStyle"/>
                <TextView android:id="@+id/accept" android:text="@string/join_accept" style="@style/MxAlbumInvitationButtonStyle"/>
            </LinearLayout>
        </LinearLayout>
    </com.samsung.android.gallery.widget.RoundedRelativeLayout>
</LinearLayout>
