<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/bottom_sheet_layout_container" android:background="@drawable/transparent_round_corner_bg" android:clipChildren="true" android:clipToPadding="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginBottom="@dimen/mapview_bottom_sheet_bottom_margin" android:layout_marginHorizontal="@dimen/mapview_bottom_sheet_side_margin" android:clipToOutline="true">
