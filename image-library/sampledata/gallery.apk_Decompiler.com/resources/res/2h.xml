<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/no_item_view_container" style="@style/ExtendedEmptyViewStyle">
            <TextView android:id="@+id/description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/noitem_description_margin_top" android:text="@string/no_sharings_description" style="@style/NoItemDescriptionStyle"/>
            <LinearLayout android:id="@+id/custom_container" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <LinearLayout android:layout_gravity="center" android:id="@+id/create_button_layout_container" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <include android:id="@+id/create_button_layout" layout="@layout/shared_album_create_button_layout"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
