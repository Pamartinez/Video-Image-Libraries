<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:tag="new_search_toolbar_containable" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:expanded="false" style="@style/AppBarLayoutStyle">
            <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" app:subtitle="@string/empty_set_description_no_items" style="@style/CollapsingToolBarStyle">
                <ViewStub android:id="@+id/custom_cover" android:layout="@layout/blur_custom_cover_layout" android:inflatedId="@+id/custom_cover" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_collapseMode="2"/>
                <include layout="@layout/floating_toolbar_dummy_view"/>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
        <RelativeLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <com.samsung.android.gallery.widget.listview.noitem.GalleryListNoItemView android:id="@+id/empty_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <FrameLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent" android:baselineAligned="false">
                <FrameLayout android:focusable="false" android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.samsung.android.gallery.widget.listview.PinchParentLayout android:focusable="false" android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.samsung.android.gallery.widget.listview.GallerySwipeView android:id="@+id/my_recycler_view" android:focusable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:importantForAccessibility="no" app:supportMultiDepth="true"/>
                        <FrameLayout android:id="@+id/fake_view_layout" android:visibility="gone" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent"/>
                    </com.samsung.android.gallery.widget.listview.PinchParentLayout>
                    <ViewStub android:layout_gravity="end" android:id="@+id/fastScrollViewStub" android:layout="@layout/fast_scroll_text_layout" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </FrameLayout>
                <FrameLayout android:layout_gravity="start" android:id="@+id/albums_left_pane" android:visibility="visible" android:layout_width="@dimen/albums_pane_width" android:layout_height="match_parent" android:paddingStart="@dimen/albums_pane_start_padding"/>
            </FrameLayout>
        </RelativeLayout>
        <com.samsung.android.gallery.widget.effects.DimView android:id="@+id/dim_view" android:background="@color/transparent" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" app:consumeTouch="false"/>
        <com.samsung.android.gallery.widget.effects.GradientView android:id="@+id/status_bar_protection_gradient" android:visibility="gone" android:layout_width="match_parent" android:layout_height="64dp" app:gradientRatio="1" app:gradientStartColor="@color/status_bar_default_gradient_color" app:gradientStartFromTop="true"/>
        <include layout="@layout/floating_toolbar_layout"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
