<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:foreground="@drawable/thumbnail_selector" android:contentDescription="@string/speak_button" android:importantForAccessibility="yes">
    <FrameLayout android:id="@+id/thumbnail_preview_layout" style="@style/ThumbnailPreviewLayoutStyle">
        <com.samsung.android.gallery.widget.PinchImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:foreground="@drawable/thumbnail_border" app:aspect_ratio="-1" style="@style/ThumbnailStyle"/>
    </FrameLayout>
    <RelativeLayout android:id="@+id/deco_view_layout" android:layout_width="match_parent" android:layout_height="match_parent">
        <ViewStub android:id="@+id/checkboxViewStub" android:layout="@layout/thumbnail_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_alignParentStart="true"/>
        <ViewStub android:id="@+id/expandViewStub" android:layout="@layout/expand_button" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_above="@+id/n_days" android:layout_alignParentEnd="true"/>
        <ViewStub android:id="@+id/storage_favorite_slot1_ViewStub" android:layout="@layout/storage_favorite_slot1" android:inflatedId="@+id/storage_favorite_slot1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_alignParentEnd="true"/>
        <ViewStub android:id="@+id/content_type_container_ViewStub" android:layout="@layout/content_type_container" android:layout_width="wrap_content" android:layout_height="@dimen/content_type_container_height" android:layout_marginBottom="@dimen/content_type_container_margin" android:layout_above="@+id/n_days" android:layout_marginStart="@dimen/content_type_container_margin" android:layout_alignParentStart="true"/>
        <TextView android:textSize="@dimen/content_n_days_text_size" android:textColor="@color/thumbnail_content_n_days_text" android:ellipsize="end" android:gravity="center" android:layout_gravity="bottom" android:id="@+id/n_days" android:background="@color/thumbnail_content_n_days_background" android:layout_width="match_parent" android:layout_height="@dimen/content_n_days_height" android:text="@null" android:maxLines="1" android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</FrameLayout>
