<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="horizontal" android:id="@+id/recycler_view_item" android:background="@drawable/recoil_list_ripple" android:focusable="true" android:clickable="false" android:clipChildren="false" android:layout_width="match_parent" android:layout_height="@dimen/list_album_item_height" android:stateListAnimator="?attr/seslLargeTouchAnimator">
    <ViewStub android:layout_gravity="center_vertical" android:id="@+id/checkboxViewStub" android:visibility="gone" android:layout="@layout/album_cover_widget_list_checkbox" android:layout_width="@dimen/check_box_width" android:layout_height="@dimen/check_box_height" android:layout_marginStart="@dimen/list_album_horizontal_gap"/>
    <FrameLayout android:layout_gravity="center_vertical" android:id="@+id/frame_view" android:clipChildren="false" android:clipToPadding="false" android:layout_width="@dimen/list_album_view_thumbnail_size" android:layout_height="@dimen/list_album_view_thumbnail_size" android:layout_marginTop="1dp" android:layout_marginBottom="1dp" android:layout_marginStart="@dimen/list_album_horizontal_gap">
        <com.samsung.android.gallery.widget.SquareImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background_dark" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ViewStub android:id="@+id/folderViewStub" android:layout="@layout/dynamic_folder_view" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ViewStub android:layout_gravity="center" android:id="@+id/emptyAlbumViewStub" android:layout="@layout/empty_album_view_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ViewStub android:layout_gravity="center" android:id="@+id/virtualAlbumViewStub" android:layout="@layout/virtual_album_view_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <LinearLayout android:layout_gravity="bottom|left|center_vertical|center_horizontal|center|start" android:orientation="horizontal" android:id="@+id/album_type_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="@dimen/album_type_layout_margin_start_list">
            <ViewStub android:id="@+id/album_type_stub" android:layout="@layout/stub_album_type" android:layout_width="wrap_content" android:layout_height="@dimen/album_type_icon_size"/>
            <ViewStub android:id="@+id/album_sync" android:layout="@layout/stub_album_sync" android:inflatedId="@+id/album_sync" android:layout_width="@dimen/album_type_icon_size" android:layout_height="@dimen/album_type_icon_size"/>
        </LinearLayout>
    </FrameLayout>
    <ViewStub android:layout_gravity="center_vertical" android:id="@+id/border_stub" android:layout="@layout/stub_album_border_view" android:layout_width="@dimen/list_album_view_thumbnail_size" android:layout_height="@dimen/list_album_view_thumbnail_size" android:layout_marginTop="1dp" android:layout_marginBottom="1dp" android:layout_marginStart="@dimen/list_album_horizontal_gap"/>
    <RelativeLayout android:orientation="vertical" android:id="@+id/title_container" android:layout_width="match_parent" android:layout_height="@dimen/list_album_item_height" android:layout_marginStart="@dimen/list_album_title_side_margin" android:layout_marginEnd="@dimen/list_album_title_side_margin">
        <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentStart="true">
            <TextView android:textSize="@dimen/album_list_title_text_size" android:textColor="@color/one_ui_album_title_text_color" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:lines="1" android:textIsSelectable="false" style="@style/OneUiRobotoRegular"/>
            <TextView android:textSize="@dimen/album_list_count_text_size" android:textColor="@color/one_ui_album_sub_title_text_color" android:ellipsize="end" android:id="@+id/count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:lines="1" android:textIsSelectable="false" style="@style/OneUiRobotoRegular"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
