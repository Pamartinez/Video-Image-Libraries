<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/filter_area" android:paddingTop="@dimen/search_filter_results_margin_top" android:layout_width="match_parent" android:layout_height="wrap_content" android:clipToOutline="true">
        <ViewStub android:id="@+id/only_them" android:layout="@layout/recycler_item_search_filters_no_theme" android:layout_width="wrap_content" android:layout_height="@dimen/search_filter_result_height" android:layout_marginEnd="@dimen/search_filter_result_item_margin_end"/>
        <com.samsung.android.gallery.widget.listview.SearchFiltersView android:id="@+id/recycler_list" android:fadingEdge="horizontal" android:fadingEdgeLength="18dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:requiresFadingEdge="horizontal"/>
        <ImageView android:id="@+id/all_filters" android:background="@drawable/search_all_filter_button_background" android:visibility="gone" android:layout_width="@dimen/search_filter_all_button_size" android:layout_height="@dimen/search_filter_all_button_size" android:src="@drawable/gallery_ic_search_more" android:tint="@color/search_category_arrow_color" android:rotation="270" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
    </LinearLayout>
    <LinearLayout android:gravity="center_vertical" android:layout_gravity="center_vertical" android:orientation="horizontal" android:id="@+id/filter_results_fuzzy_container" android:paddingTop="@dimen/search_filter_results_margin_top" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp">
        <ImageView android:layout_width="@dimen/search_filter_results_fuzzy_icon_size" android:layout_height="@dimen/search_filter_results_fuzzy_icon_size" android:src="@drawable/gallery_ic_menu_suggestion" android:tint="@color/search_fuzzy_help_icon_tint_color" android:layout_marginEnd="@dimen/search_filter_results_fuzzy_icon_end_margin"/>
        <TextView android:id="@+id/filter_results_fuzzy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/fuzzy_showing_result_for" style="@style/SearchFilterResultTextStyle"/>
    </LinearLayout>
</LinearLayout>
