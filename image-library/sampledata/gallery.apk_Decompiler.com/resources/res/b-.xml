<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:focusable="true" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/search_item_margin_top" android:layout_marginBottom="@dimen/search_item_margin_bottom" android:layout_marginHorizontal="@dimen/search_item_card_thumbnail_spacing">
    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:importantForAccessibility="noHideDescendants">
        <com.samsung.android.gallery.widget.SquareImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content" app:aspect_ratio="0.75"/>
        <ImageView android:layout_gravity="bottom|right|center_vertical|center_horizontal|center|end" android:id="@+id/poi_icon" android:visibility="gone" android:layout_width="@dimen/search_item_grid_poi_size" android:layout_height="@dimen/search_item_grid_poi_size" android:layout_marginBottom="@dimen/search_poi_icon_margin_top" android:tint="@color/white_color" android:contentDescription="@null" android:layout_marginEnd="@dimen/search_poi_icon_margin_top"/>
    </FrameLayout>
    <TextView android:textSize="@dimen/album_grid_title_text_size" android:textColor="@color/search_category_item_title_color" android:ellipsize="end" android:layout_gravity="center_horizontal" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/album_grid_title_top_margin" android:layout_marginBottom="@dimen/album_grid_title_bottom_margin" android:maxLines="1" android:textIsSelectable="false" style="@style/OneUiRobotoRegular"/>
    <TextView android:textSize="@dimen/search_category_item_grid_count_text_size" android:textColor="@color/search_category_item_count_color" android:ellipsize="end" android:layout_gravity="center_horizontal" android:id="@+id/count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" style="@style/OneUiRobotoRegular"/>
</LinearLayout>
