<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.viewpager2.widget.ViewPager2 android:orientation="horizontal" android:id="@+id/mirroring_view_pager" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <RelativeLayout android:visibility="visible" android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:textSize="@dimen/presentation_info_text_size" android:id="@+id/presentation_location" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/presentation_info_text_top_margin" android:layout_alignParentTop="true" android:layout_marginStart="@dimen/presentation_info_text_side_margin" android:layout_alignParentStart="true" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/presentation_info_text_size" android:id="@+id/presentation_date_time" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/presentation_info_text_top_margin" android:layout_alignParentTop="true" android:layout_marginEnd="@dimen/presentation_info_text_side_margin" android:layout_alignParentEnd="true" style="@style/OneUiRobotoRegular"/>
        <ImageView android:id="@+id/mirror_prev_icon" android:background="@drawable/presentation_previous_button" android:visibility="gone" android:clickable="true" android:layout_width="@dimen/presentation_button_bg_size" android:layout_height="@dimen/presentation_button_bg_size" android:layout_centerVertical="true" android:contentDescription="@string/prev_item" android:layout_marginStart="@dimen/horizontal_navigation_icon_margin" android:layout_alignParentStart="true"/>
        <ImageView android:id="@+id/mirror_next_icon" android:background="@drawable/presentation_next_button" android:visibility="gone" android:clickable="true" android:layout_width="@dimen/presentation_button_bg_size" android:layout_height="@dimen/presentation_button_bg_size" android:layout_centerVertical="true" android:contentDescription="@string/next_item" android:layout_marginEnd="@dimen/horizontal_navigation_icon_margin" android:layout_alignParentEnd="true"/>
        <ImageView android:id="@+id/mirror_close_icon" android:background="@drawable/presentation_close_button" android:visibility="gone" android:clickable="true" android:layout_width="@dimen/presentation_button_bg_size" android:layout_height="@dimen/presentation_button_bg_size" android:layout_marginTop="@dimen/horizontal_navigation_icon_margin" android:layout_alignParentTop="true" android:contentDescription="@string/close" android:layout_marginEnd="@dimen/horizontal_navigation_icon_margin" android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</RelativeLayout>
