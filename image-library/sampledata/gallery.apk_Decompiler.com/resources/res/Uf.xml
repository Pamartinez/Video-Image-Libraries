<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="horizontal" android:id="@+id/recycler_view_item" android:background="@drawable/recoil_list_ripple" android:focusable="true" android:clickable="false" android:clipChildren="false" android:layout_width="match_parent" android:layout_height="80dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:stateListAnimator="?attr/seslLargeTouchAnimator">
    <ImageView android:id="@+id/icon" android:layout_width="36dp" android:layout_height="36dp" android:layout_centerVertical="true" android:layout_marginStart="9dp"/>
    <com.samsung.android.gallery.widget.SquareImageView android:id="@+id/image" android:background="@color/thumbnail_icon_background" android:focusable="false" android:clickable="false" android:layout_width="54dp" android:layout_height="54dp" android:cropToPadding="true" android:layout_centerVertical="true" android:layout_marginEnd="20dp" android:layout_alignParentStart="true"/>
    <TextView android:textSize="14dp" android:textColor="@color/one_ui_header_title_text_color" android:ellipsize="start" android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Download" android:maxLines="1" android:fontFamily="" android:layout_marginStart="64dp" style="@style/OneUiRobotoSemiBold"/>
    <TextView android:id="@+id/subtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="5th Jan 13:00PM, 2023" android:maxLines="1" android:layout_below="@+id/title" android:layout_toStartOf="@+id/info" android:layout_alignStart="@+id/title" style="@style/OneUiRobotoRegular"/>
    <TextView android:id="@+id/info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12KB" android:maxLines="1" android:layout_alignBottom="@+id/subtitle" android:layout_marginStart="10dp" android:layout_alignParentEnd="true" style="@style/OneUiRobotoRegular"/>
    <View android:background="@color/light_gray" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="2dp" android:layout_alignParentBottom="true" android:layout_marginStart="60dp"/>
</RelativeLayout>
