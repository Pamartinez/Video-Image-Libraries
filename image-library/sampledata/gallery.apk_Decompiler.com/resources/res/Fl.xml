<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/ts_foreground" android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:paddingStart="12dp" android:paddingEnd="12dp">
    <TextView android:textSize="16sp" android:textColor="@android:color/black" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Title" android:fontFamily="sec-roboto-regular"/>
    <TextView android:textSize="14sp" android:id="@+id/summary" android:paddingTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Summary" android:layout_below="@+id/title"/>
    <TextView android:textSize="14sp" android:textColor="@color/ts_todo" android:gravity="start" android:id="@+id/todo" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@+id/summary" android:layout_toStartOf="@+id/button" android:layout_alignParentStart="true"/>
    <Button android:textSize="13sp" android:textColor="#000000" android:id="@+id/button" android:paddingTop="0dp" android:paddingBottom="0dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="26dp" android:text="Resolve" android:includeFontPadding="false" android:layout_alignTop="@+id/todo" android:layout_alignBottom="@+id/todo" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_alignParentEnd="true" android:backgroundTint="#cccccc"/>
</RelativeLayout>
