<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
    <LinearLayout android:orientation="vertical" android:id="@+id/view_icon_container" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:background="@drawable/gallery360viewer_viewmode_shape_rectangle" android:layout_width="match_parent" android:layout_height="wrap_content" android:baselineAligned="false" android:layout_marginStart="@dimen/gallery360viewer_view_mode_bar_margin_side" android:layout_marginEnd="@dimen/gallery360viewer_view_mode_bar_margin_side">
            <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_dual_view" android:tag="3" android:contentDescription="@string/gallery360viewer_mode_dual_view" android:tooltipText="@string/gallery360viewer_mode_dual_view" app:depth="2" app:image="@drawable/gallery_ic_detail_dual" app:text="@string/gallery360viewer_mode_dual" style="@style/Image360ViewIconStyle"/>
            <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_panoramic_view" android:tag="4" android:contentDescription="@string/gallery360viewer_mode_panorama_view" android:tooltipText="@string/gallery360viewer_mode_panorama_view" app:depth="2" app:image="@drawable/gallery_ic_detail_panoramic" app:text="@string/gallery360viewer_mode_panorama" style="@style/Image360ViewIconStyle"/>
            <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_360_view" android:tag="0" android:contentDescription="@string/gallery360viewer_mode_360_view" android:tooltipText="@string/gallery360viewer_mode_360_view" app:depth="2" app:image="@drawable/gallery_ic_detail_360_view" app:text="@string/gallery360viewer_mode_360" style="@style/Image360ViewIconStyle"/>
            <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_round_view" android:tag="1" android:contentDescription="@string/gallery360viewer_mode_round_view" android:tooltipText="@string/gallery360viewer_mode_round_view" app:depth="2" app:image="@drawable/gallery_ic_detail_round" app:text="@string/gallery360viewer_mode_round" style="@style/Image360ViewIconStyle"/>
            <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_stretched_view" android:tag="2" android:contentDescription="@string/gallery360viewer_mode_stretched_view" android:tooltipText="@string/gallery360viewer_mode_stretched_view" app:depth="2" app:image="@drawable/gallery_ic_detail_stretch" app:text="@string/gallery360viewer_mode_stretched" style="@style/Image360ViewIconStyle"/>
        </LinearLayout>
        <LinearLayout android:gravity="end" android:orientation="horizontal" android:id="@+id/bubble_picker_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/gallery360viewer_bubble_picker_margin_bottom" android:weightSum="3">
            <RelativeLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:background="@color/viewer_floating_menu_background_color" android:layout_width="match_parent" android:layout_height="@dimen/gallery360viewer_fast_option_bg_height" android:baselineAligned="false">
        <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_motion_view" android:contentDescription="@string/gallery360viewer_motion_view" android:tooltipText="@string/gallery360viewer_motion_view" app:depth="1" app:image="@drawable/gallery_ic_detail_motion_view" app:text="@string/gallery360viewer_motion_view" style="@style/Image360FastOptionItemStyle"/>
        <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_reset" android:contentDescription="@string/gallery360viewer_reset" android:tooltipText="@string/gallery360viewer_reset" app:depth="1" app:image="@drawable/gallery_ic_detail_reset_view" app:text="@string/gallery360viewer_reset" style="@style/Image360FastOptionItemStyle"/>
        <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_mode_selector" android:contentDescription="@null" app:depth="1" style="@style/Image360FastOptionItemStyle"/>
        <com.samsung.android.gallery.image360.widget.Image360FastOptionItem android:id="@+id/btn_more" android:contentDescription="@string/more_options" android:tooltipText="@string/more_options" app:depth="1" app:image="@drawable/gallery_ic_ab_more" style="@style/Image360FastOptionItemStyle"/>
    </LinearLayout>
</LinearLayout>
