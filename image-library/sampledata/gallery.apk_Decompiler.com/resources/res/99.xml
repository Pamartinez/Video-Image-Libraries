            <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:background="@color/transparent" app:customPreference="appbar_collection" app:expanded="true" style="@style/AppBarLayoutStyle">
