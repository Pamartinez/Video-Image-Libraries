<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/main_layout" android:layout_width="match_parent" android:layout_height="match_parent">
    <ViewStub android:id="@+id/top_color_effect_layout_stub" android:layout="@layout/top_color_effect_layout" android:layout_width="match_parent" android:layout_height="@dimen/stories_top_color_effect_view_height"/>
    <FrameLayout android:id="@+id/coordinator_slide_panel" android:layout_width="match_parent" android:layout_height="match_parent">
