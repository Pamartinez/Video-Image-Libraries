                <com.samsung.android.gallery.widget.flexboxlist.FlexBoxListView android:id="@+id/floating_suggestion_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:layout_marginHorizontal="@dimen/search_floating_recommend_suggested_list_margin_horizontal"/>
