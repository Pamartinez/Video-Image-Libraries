<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/floating_history_container" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:id="@+id/floating_history_title_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/search_floating_recommend_history_title_margin_top" android:layout_marginBottom="@dimen/search_floating_recommend_history_title_margin_bottom" android:paddingHorizontal="@dimen/search_floating_recommend_title_padding_horizontal">
        <TextView android:gravity="left|center_vertical|center_horizontal|center|start" android:layout_width="0dp" android:layout_height="wrap_content" android:text="@string/recent_search" android:layout_weight="1" style="@style/FloatingRecommendationTitleTextStyle"/>
        <TextView android:textSize="12dp" android:textColor="@color/search_clear_history_button_text_color" android:gravity="right|center_vertical|center_horizontal|center|end" android:id="@+id/clear_history_button" android:background="@drawable/button_ripple" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/delete_history" android:paddingHorizontal="@dimen/search_floating_recommend_title_button_padding_horizontal" android:paddingVertical="@dimen/search_count_header_view_by_vertical_margin" style="@style/FloatingRecommendationTitleTextStyle"/>
    </LinearLayout>
    <com.samsung.android.gallery.widget.RoundedFrameLayout android:background="@color/floating_recommendation_chunking_bg_color" android:paddingTop="@dimen/search_floating_recommend_history_list_padding_top" android:paddingBottom="@dimen/search_floating_recommend_history_list_padding_bottom" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/search_floating_recommend_history_list_margin_bottom" android:layout_marginHorizontal="@dimen/search_floating_recommend_history_list_margin_horizontal" android:paddingHorizontal="@dimen/search_floating_recommend_history_list_padding_horizontal">
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/floating_history_view" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
    </com.samsung.android.gallery.widget.RoundedFrameLayout>
</LinearLayout>
