<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="wrap_content" android:layout_height="wrap_content">
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/container" android:background="@drawable/search_toolbar_filter_item_background" android:focusable="true" android:clickable="true" android:layout_width="wrap_content" android:layout_height="@dimen/search_toolbar_chip_height" android:layout_marginEnd="4dp">
        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ImageView android:id="@+id/circle_thumb" android:background="@drawable/circular_thumb_background" android:visibility="gone" android:layout_width="@dimen/search_filter_result_item_icon_size_for_person" android:layout_height="@dimen/search_filter_result_item_icon_size_for_person" android:layout_margin="1dp"/>
            <ImageView android:id="@+id/round_thumb" android:background="@drawable/round_thumb_background" android:visibility="gone" android:layout_width="45dp" android:layout_height="@dimen/search_filter_result_item_icon_size_for_person" android:layout_margin="1dp"/>
        </FrameLayout>
        <LinearLayout android:orientation="horizontal" android:id="@+id/subContainer" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginHorizontal="@dimen/search_toolbar_chip_side_margin">
            <ImageView android:layout_gravity="center_vertical" android:id="@+id/type_icon" android:visibility="visible" android:layout_width="@dimen/search_toolbar_chip_icon_size" android:layout_height="@dimen/search_toolbar_chip_icon_size" android:tint="@color/search_history_text_color" android:layout_marginEnd="@dimen/search_toolbar_chip_type_title_margin_start"/>
            <TextView android:textSize="@dimen/search_toolbar_chip_text_size" android:textColor="@color/search_history_text_color" android:ellipsize="end" android:layout_gravity="center_vertical" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="200dp" android:maxLines="1" style="@style/OneUiRobotoRegular"/>
            <ImageView android:layout_gravity="center_vertical" android:id="@+id/delete_icon" android:background="?android:attr/selectableItemBackgroundBorderless" android:focusable="false" android:visibility="visible" android:clickable="true" android:layout_width="@dimen/search_toolbar_chip_close_button_size" android:layout_height="@dimen/search_toolbar_chip_close_button_size" android:src="@drawable/gallery_ic_search_edit_no" android:tint="@color/search_history_text_color" android:layout_marginStart="@dimen/search_toolbar_chip_delete_icon_margin_start" android:tooltipText="@string/delete_button_label"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
