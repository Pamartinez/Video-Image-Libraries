<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:expanded="false" style="@style/AppBarLayoutStyle">
        <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" style="@style/CollapsingToolBarStyle">
            <ViewStub android:id="@+id/custom_cover" android:inflatedId="@+id/custom_cover" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_collapseMode="2"/>
            <include layout="@layout/floating_toolbar_dummy_view"/>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <ViewStub android:id="@+id/one_person_shared_album_notice_view_stub" android:layout="@layout/sharing_pictures_one_person_shared_album_notice_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="@dimen/one_person_shared_album_notice_view_margin_start" android:layout_marginEnd="@dimen/one_person_shared_album_notice_view_margin_end" android:layout_marginVertical="@dimen/one_person_shared_album_notice_view_margin_vertical"/>
        <androidx.core.widget.NestedScrollView android:id="@+id/empty_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <RelativeLayout android:gravity="center_vertical" android:id="@+id/no_item_view_container" style="@style/ExtendedEmptyViewStyle">
                    <com.samsung.android.gallery.widget.NoItemView android:id="@+id/no_item_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" app:description="@string/no_shared_item_description" app:label="@string/no_shared_items"/>
                    <include android:layout_gravity="center" android:id="@+id/add_family_button_layout" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/family_shared_add_family_button_margin_top" android:layout_below="@+id/no_item_view" android:layout_centerInParent="true" layout="@layout/shared_album_add_family_button_layout"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <include android:layout_width="match_parent" android:layout_height="match_parent" layout="@layout/gallery_list_view"/>
    </LinearLayout>
    <com.samsung.android.gallery.widget.effects.GradientView android:id="@+id/status_bar_protection_gradient" android:visibility="gone" android:layout_width="match_parent" android:layout_height="64dp" app:gradientRatio="1" app:gradientStartColor="@color/status_bar_default_gradient_color" app:gradientStartFromTop="true"/>
    <include layout="@layout/floating_toolbar_layout"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
