<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_gravity="center_vertical" android:orientation="horizontal" android:id="@+id/deco_view_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="@dimen/search_cluster_results_album_type_title_padding_start" android:paddingEnd="@dimen/search_cluster_results_album_type_title_padding_end">
