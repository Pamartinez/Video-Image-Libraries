        </RelativeLayout>
        <LinearLayout android:gravity="center_horizontal" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginHorizontal="@dimen/suggestions_card_margin_horizontal" android:layout_marginVertical="@dimen/suggestions_card_padding_vertical">
