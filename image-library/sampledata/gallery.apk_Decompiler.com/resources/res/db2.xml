<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/search_count_header_margin_bottom" android:paddingHorizontal="@dimen/search_cluster_results_horizontal_padding">
    <RelativeLayout android:id="@+id/search_cluster_title_header" android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:id="@+id/item_count_line" android:background="@color/search_count_header_background_line_color" android:layout_width="match_parent" android:layout_height="@dimen/search_count_header_background_line" android:layout_centerInParent="true"/>
        <TextView android:textSize="@dimen/search_cluster_results_title_font_size" android:textColor="@color/story_search_result_title_color" android:id="@+id/search_cluster_divider_title" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/all_results" android:layout_centerVertical="true" android:layout_marginEnd="@dimen/search_cluster_results_title_header_text_gap" android:layout_alignParentStart="true" style="@style/OneUiRobotoSemiBold"/>
        <TextView android:textSize="@dimen/search_cluster_results_count_font_size" android:textColor="@color/story_search_result_count_color" android:id="@+id/item_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100" android:layout_centerVertical="true" android:layout_toEndOf="@+id/search_cluster_divider_title" style="@style/OneUiRobotoLight"/>
        <ImageView android:id="@+id/map_all" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/gallery_ic_search_location" android:tint="@color/mx_divider_view_all_color" android:layout_centerVertical="true" android:layout_marginEnd="3dp" android:layout_toStartOf="@+id/view_by" android:stateListAnimator="?attr/seslSmallTouchAnimator" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/search_cluster_results_view_by_size" android:textColor="@color/mx_divider_view_all_color" android:id="@+id/view_by" android:background="@drawable/recoil_button_ripple" android:focusable="true" android:visibility="visible" android:clickable="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/group_by_date" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:fontWeight="@integer/font_weight_400" android:paddingHorizontal="@dimen/search_count_header_view_by_horizontal_margin" android:paddingVertical="@dimen/search_count_header_view_by_vertical_margin" style="@style/OneUiRobotoSemiBold"/>
        <ImageView android:id="@+id/search_cluster_divider_arrow" android:visibility="gone" android:layout_centerVertical="true" android:layout_alignParentEnd="true" style="@style/SearchCategoryArrowStyle"/>
    </RelativeLayout>
</RelativeLayout>
