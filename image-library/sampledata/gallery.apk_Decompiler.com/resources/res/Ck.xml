<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:background="@drawable/recoil_list_ripple" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="@dimen/shared_view_item_horizontal_gap" android:paddingEnd="@dimen/shared_photo_cover_layout_start_margin" android:stateListAnimator="?attr/seslLargeTouchAnimator" android:paddingVertical="@dimen/shared_view_item_vertical_bottom_space">
    <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
        <com.samsung.android.gallery.widget.PinchImageView android:id="@+id/thumbnail" android:background="@color/text_color_white" android:focusable="false" android:clickable="false" android:layout_width="@dimen/shared_thumbnail_size_one_ui_50" android:layout_height="@dimen/shared_thumbnail_size_one_ui_50" android:cropToPadding="true"/>
        <ImageView android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/album_expiry_notice_icon" android:background="@drawable/gallery_ic_error_notice_badge" android:visibility="gone" android:layout_width="@dimen/sharing_view_grid_expiry_size" android:layout_height="@dimen/sharing_view_grid_expiry_size" android:layout_marginTop="@dimen/sharing_view_grid_expiry_icon_margin_3x" android:layout_marginEnd="@dimen/sharing_view_grid_expiry_icon_margin_3x"/>
        <ViewStub android:layout_gravity="bottom|left|center_vertical|center_horizontal|center|start" android:id="@+id/album_type_stub" android:layout="@layout/stub_album_type" android:inflatedId="@+id/album_type" android:layout_width="15dp" android:layout_height="15dp"/>
    </FrameLayout>
    <LinearLayout android:gravity="center_vertical" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginStart="@dimen/sharing_view_list_description_start_margin">
        <RelativeLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/album_grid_title_top_margin" android:layout_marginBottom="@dimen/album_grid_title_bottom_margin">
            <com.samsung.android.gallery.widget.GalleryTextView android:textSize="@dimen/sharing_view_list_title_size" android:textColor="@color/one_ui_album_title_text_color" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:layout_marginEnd="@dimen/new_badge_dot_size" style="@style/OneUiRobotoRegular"/>
            <ImageView android:id="@+id/newLabel" android:visibility="gone" android:layout_marginStart="@dimen/new_badge_dot_minus_margin" android:layout_toEndOf="@+id/title" style="@style/NewDotStyle"/>
        </RelativeLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="@dimen/sharing_view_list_sub_title_size" android:textColor="@color/shared_sub_title_icon_tint_color" android:id="@+id/count" android:padding="0dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/OneUiRobotoRegular"/>
            <ImageView android:layout_gravity="center" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/shared_album_sub_title_dot" android:layout_marginHorizontal="@dimen/sharing_view_sub_title_gap"/>
            <TextView android:textSize="@dimen/sharing_view_list_sub_title_size" android:textColor="@color/shared_sub_title_icon_tint_color" android:id="@+id/member_count" android:padding="0dp" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/OneUiRobotoRegular"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:textSize="13dp" android:textColor="@color/shared_sub_title_icon_tint_color" android:ellipsize="end" android:gravity="center" android:id="@+id/subtitle" android:background="@drawable/sharing_group_information_shape" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="@dimen/shared_group_layout_min_height" android:maxLines="2" android:layout_weight="1" android:textIsSelectable="false" android:textAlignment="center" android:paddingStart="@dimen/shared_view_bg_start_end_padding" android:paddingEnd="@dimen/shared_view_bg_start_end_padding" android:layout_marginStart="@dimen/shared_owner_start_margin" style="@style/OneUiRobotoRegular"/>
                <ImageView android:id="@+id/icon" android:visibility="gone" android:layout_width="@dimen/shared_crown_size" android:layout_height="@dimen/shared_crown_size" android:src="@drawable/sharings_crown" android:contentDescription="@string/group_creator" android:layout_marginStart="@dimen/sharing_view_sub_title_gap" android:tooltipText="@string/group_creator"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
