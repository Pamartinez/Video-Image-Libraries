<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/recycler_item_view" android:focusable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:id="@+id/content_parent" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:id="@+id/thumbnail_container" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:stateListAnimator="?attr/seslLargeTouchAnimator">
            <com.samsung.android.gallery.widget.ShapeImageView android:id="@+id/thumbnail" android:contentDescription="@null" app:aspect_ratio="-1" style="@style/ThumbnailStyle"/>
            <FrameLayout android:id="@+id/thumbnail_preview_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <View android:id="@+id/gradient_view" android:background="@drawable/stories_pinch_item_lower_gradient" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="2px"/>
            <ImageView android:id="@+id/shape_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
        </FrameLayout>
        <RelativeLayout android:orientation="vertical" android:id="@+id/deco_layout" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:gravity="center_vertical" android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/top_right_deco" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="22dp" android:layout_alignParentTop="true" android:layout_alignParentEnd="true">
                <TextView android:textSize="8dp" android:id="@+id/newLabel" android:text="@string/new_label" android:textAllCaps="true" style="@style/StoryNewBadgeStyle"/>
            </LinearLayout>
            <RelativeLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:layout_alignParentBottom="true" android:layout_marginHorizontal="24dp">
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/title_area" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <TextView android:id="@+id/title" android:includeFontPadding="false" android:layout_centerHorizontal="true" style="@style/StoriesCategoryTitleStyle"/>
                </LinearLayout>
                <TextView android:id="@+id/duration" android:layout_marginBottom="10dp" android:layout_below="@+id/title_area" style="@style/StoriesCategorySubTitleStyle"/>
                <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="31dp" android:layout_below="@+id/duration">
                    <ImageView android:gravity="center_vertical" android:layout_gravity="end" android:id="@+id/icon_favorite" android:background="@drawable/story_highlight_filter_btn_bg" android:padding="4dp" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="31dp" android:layout_height="31dp" android:src="@drawable/story_favorite_off" android:contentDescription="@string/add_to_favorites" android:layout_marginEnd="9dp" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:tooltipText="@string/add_to_favorites"/>
                    <ImageView android:gravity="center_vertical" android:layout_gravity="end" android:id="@+id/icon_save" android:background="@drawable/story_highlight_filter_btn_bg" android:padding="4dp" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="31dp" android:layout_height="31dp" android:src="@drawable/gallery_ic_cover_collection_on" android:contentDescription="@string/save_story" android:layout_marginEnd="9dp" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:tooltipText="@string/save_story"/>
                    <LinearLayout android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/play_switch_layout" android:background="@drawable/story_highlight_deco_background" android:layout_width="wrap_content" android:layout_height="match_parent" android:minHeight="@dimen/story_highlight_deco_duration_min_height" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginEnd="9dp" android:screenReaderFocusable="true">
                        <LinearLayout android:gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="27dp">
                            <TextView android:textSize="@dimen/story_highlight_deco_play_duration_text_size" android:textColor="@color/white" android:id="@+id/play_count" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/OneUiRobotoRegular"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:gravity="center_vertical" android:id="@+id/hourglass_layout" android:background="@drawable/story_highlight_deco_background" android:layout_width="wrap_content" android:layout_height="match_parent" android:minHeight="@dimen/story_highlight_deco_duration_min_height" android:contentDescription="@string/pause_video" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginEnd="9dp">
                        <ImageView android:id="@+id/hourglass_icon" android:layout_width="@dimen/stories_category_hourglass_width" android:layout_height="@dimen/stories_category_hourglass_height" android:foreground="@drawable/recoil_ripple_oval" android:src="@drawable/hourglass" android:tint="@color/white_color" android:layout_marginEnd="3dp" android:stateListAnimator="?attr/seslSmallTouchAnimator"/>
                        <TextView android:textSize="@dimen/story_highlight_deco_play_duration_text_size" android:textColor="@color/white" android:id="@+id/hourglass_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 days" android:maxLines="1" style="@style/OneUiRobotoRegular"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>
    </FrameLayout>
</FrameLayout>
