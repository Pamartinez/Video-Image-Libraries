<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center" android:orientation="vertical" android:paddingTop="@dimen/simple_progress_dialog_padding_top" android:paddingBottom="@dimen/simple_progress_dialog_padding_bottom" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="@dimen/simple_progress_dialog_padding_start_end" android:paddingEnd="@dimen/simple_progress_dialog_padding_start_end">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="8dp" android:paddingEnd="8dp">
        <CheckBox android:id="@+id/startAnimation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true"/>
        <TextView android:textSize="16sp" android:textColor="@color/black_color" android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1000ms" android:layout_centerHorizontal="true" android:layout_centerVertical="true"/>
        <CheckBox android:id="@+id/endAnimation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <SeekBar android:layout_gravity="bottom" android:id="@+id/seekBar" android:paddingTop="@dimen/seek_bar_top_padding" android:paddingBottom="@dimen/seek_bar_bottom_padding" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/seek_bar_bottom_margin" android:max="20" android:progress="10" android:thumb="@drawable/gallery_detail_seek_bar_thumb" android:paddingStart="@dimen/seek_bar_side_margin" android:paddingEnd="@dimen/seek_bar_side_margin" android:progressTint="#802099d6" android:thumbTint="@color/thumbnail_bt_focused" style="@style/Widget.Material.Light.SeekBar"/>
</LinearLayout>
