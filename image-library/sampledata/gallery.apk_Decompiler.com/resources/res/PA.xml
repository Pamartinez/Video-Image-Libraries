<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item android:state_pressed="false">
        <shape android:shape="oval">
            <solid android:color="@android:color/holo_blue_dark"/>
        </shape>
    </item>
    <item android:state_pressed="true">
