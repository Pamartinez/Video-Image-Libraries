                <include android:id="@+id/floating_my_tag_layout" layout="@layout/floating_recommendation_item_layout"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.samsung.android.gallery.widget.listview.TouchParentLayout>
    <include layout="@layout/floating_toolbar_layout"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
