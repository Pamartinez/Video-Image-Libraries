<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:background="@drawable/sharingv2_invitation_bg" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="@dimen/shared_view_item_horizontal_gap">
    <RelativeLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/sharingv2_invitation_layout_top_margin" android:layout_marginStart="@dimen/sharingv2_invitation_layout_top_margin">
        <ImageView android:id="@+id/invitation_icon_view" android:background="@drawable/sharingv2_invitation_icon_bg" android:focusable="false" android:visibility="visible" android:clickable="false" android:layout_width="@dimen/invitation_host_icon_size" android:layout_height="@dimen/invitation_host_icon_size" android:scaleType="fitCenter" android:cropToPadding="true"/>
    </RelativeLayout>
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/sharingv2_invitation_layout_top_margin" android:layout_marginBottom="@dimen/sharingv2_invitation_bottom_margin" android:layout_marginStart="@dimen/shared_photo_cover_layout_start_margin" android:layout_marginEnd="@dimen/sharingv2_invitation_accept_button_margin_end">
        <TextView android:textSize="@dimen/shared_view_title_font_size" android:textColor="@color/sharingv2_invitation_title_text_color" android:ellipsize="end" android:id="@+id/host" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:letterSpacing="0" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/shared_view_group_font_size" android:textColor="@color/sharingv2_invitation_title_text_color" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:letterSpacing="0" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/shared_view_group_font_size" android:textColor="@color/sharingv2_invitation_date_text_color" android:ellipsize="end" android:id="@+id/expire_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/sharingv2_invitation_date_text_margin_bottom" android:maxLines="1" android:textIsSelectable="false" android:letterSpacing="0" style="@style/OneUiRobotoRegular"/>
        <LinearLayout android:gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="@dimen/shared_view_title_font_size" android:textColor="@color/sharingv2_invitation_button_text_color" android:ellipsize="end" android:id="@+id/decline" android:background="@drawable/recoil_ripple_rect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/join_decline" android:maxLines="1" android:textIsSelectable="false" android:layout_marginEnd="@dimen/sharingv2_invitation_decline_button_margin_end" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:letterSpacing="0" style="@style/OneUiRobotoSemiBold"/>
            <TextView android:textSize="@dimen/shared_view_title_font_size" android:textColor="@color/sharingv2_invitation_button_text_color" android:ellipsize="end" android:id="@+id/accept" android:background="@drawable/recoil_ripple_rect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/join_accept" android:maxLines="1" android:textIsSelectable="false" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:letterSpacing="0" style="@style/OneUiRobotoSemiBold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
