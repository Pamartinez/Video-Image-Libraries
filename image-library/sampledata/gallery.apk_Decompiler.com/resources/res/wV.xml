<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/deco_view_layout" android:layout_width="match_parent" android:layout_height="wrap_content">
    <RelativeLayout android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="3dp">
        <TextView android:textSize="@dimen/search_cluster_results_carousel_count_text_size" android:textColor="@color/story_search_result_count_color" android:ellipsize="end" android:id="@+id/result_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:layout_centerVertical="true" android:textDirection="locale" android:textAlignment="viewStart" android:textFontWeight="@integer/font_weight_500" style="@style/OneUiRobotoSemiBold"/>
        <ImageView android:id="@+id/search_cluster_divider_arrow" android:layout_toStartOf="@+id/result_count" android:layout_alignParentEnd="true" style="@style/SearchCategoryArrowStyle"/>
    </RelativeLayout>
    <TextView android:textSize="@dimen/search_cluster_results_carousel_title_text_size" android:textColor="@color/search_card_header_title" android:ellipsize="end" android:gravity="start" android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="2" android:fontFamily="roboto" android:textDirection="locale" android:textAlignment="viewStart" android:paddingStart="1dp" android:textFontWeight="@integer/font_weight_500" style="@style/OneUiRobotoSemiBold"/>
</LinearLayout>
