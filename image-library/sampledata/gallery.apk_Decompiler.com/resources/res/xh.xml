<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="wrap_content">
    <FrameLayout android:id="@+id/thumbnail_container" android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageView android:id="@+id/thumbnail" android:contentDescription="@null" style="@style/ThumbnailStyle"/>
        <View android:id="@+id/gradient_view" android:background="@drawable/stories_pinch_item_lower_gradient" android:layout_width="match_parent" android:layout_height="match_parent"/>
    </FrameLayout>
    <LinearLayout android:gravity="center_horizontal" android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:orientation="vertical" android:id="@+id/title_container" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/story_highlight_related_item_title_text_size" android:textStyle="bold" android:textColor="@color/stories_pinch_item_title_color" android:id="@+id/title" android:layout_marginBottom="@dimen/story_highlight_related_title_bottom_margin" android:maxLines="2" android:fontFamily="roboto" android:textAlignment="center" android:textFontWeight="700" style="@style/StoriesItemTitleStyle"/>
        <TextView android:textSize="@dimen/story_highlight_related_item_duration_text_size" android:textColor="@color/stories_pinch_item_sub_title_color" android:id="@+id/duration" android:textFontWeight="400" style="@style/StoriesItemSubTitleStyle"/>
    </LinearLayout>
</FrameLayout>
