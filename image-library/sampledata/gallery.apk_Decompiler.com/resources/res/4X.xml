            <com.samsung.android.gallery.widget.photoview.PhotoViewCompat android:id="@+id/photo_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:adjustViewBounds="true" android:importantForAccessibility="no" android:defaultFocusHighlightEnabled="false" app:aliveZoom="false" app:doubleTapZoomType="unlimited" app:minSize="@dimen/remaster_viewer_min_size"/>
