<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="@dimen/third_party_access_layout_padding_horizontal">
        <TextView android:textSize="@dimen/third_party_access_layout_header_text_size" android:textColor="@color/third_party_access_layout_header_text_color" android:id="@+id/header" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textDirection="locale" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/third_party_access_layout_title_text_size" android:textColor="@color/third_party_access_layout_description_title_text_color" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/third_party_access_layout_title_margin_top" android:textDirection="locale" style="@style/OneUiRobotoRegular"/>
        <TextView android:textSize="@dimen/third_party_access_layout_description_text_size" android:textColor="@color/third_party_access_layout_description_text_color" android:id="@+id/description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textDirection="locale" style="@style/OneUiRobotoRegular"/>
        <LinearLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/third_party_access_layout_divider_margin_top">
            <ImageView android:layout_gravity="center" android:background="@drawable/third_party_access_divider" android:layout_width="0dp" android:layout_height="@dimen/third_party_access_layout_divider_height" android:layout_weight="1" android:layerType="software"/>
        </LinearLayout>
        <include android:id="@+id/service_provider" layout="@layout/third_party_access_category_layout"/>
        <include android:id="@+id/data_required_permission" layout="@layout/third_party_access_category_layout"/>
        <include android:id="@+id/purpose" layout="@layout/third_party_access_category_layout"/>
        <include android:id="@+id/terms_and_conditions" layout="@layout/third_party_access_category_layout"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
