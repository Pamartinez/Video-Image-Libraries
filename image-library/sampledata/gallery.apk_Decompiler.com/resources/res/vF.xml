<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:tag="new_search_toolbar_containable" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout android:id="@+id/main_layout" android:layout_width="match_parent" android:layout_height="match_parent">
        <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:expanded="false" app:seslHeightProportion="0" app:seslUseCustomHeight="true" style="@style/AppBarLayoutStyle">
            <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" app:subtitle="@null" app:title="@string/search" style="@style/CollapsingToolBarStyle">
                <include layout="@layout/floating_toolbar_dummy_view"/>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
        <LinearLayout android:orientation="vertical" android:focusable="false" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <FrameLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent">
                <ViewStub android:id="@+id/empty_view" android:layout="@layout/fragment_search_emptyview_stub" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <ViewStub android:id="@+id/empty_view_by_hidden" android:layout="@layout/fragment_search_people_emptyview_stub" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <com.samsung.android.gallery.widget.listview.GalleryListView android:id="@+id/my_recycler_view" android:paddingTop="@dimen/search_category_list_padding_top" android:focusable="false" android:scrollbars="none" android:clipToPadding="false" android:layoutAnimation="@anim/layout_anim_alpha_no_delay" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="@dimen/search_card_padding_horizontal"/>
                <com.samsung.android.gallery.widget.flexboxlist.FlexBoxListView android:id="@+id/flex_box_list" android:paddingTop="@dimen/search_category_tag_padding_top" android:clipToPadding="false" android:layoutAnimation="@anim/layout_anim_alpha_no_delay" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="@dimen/search_card_padding_horizontal_for_tag"/>
            </FrameLayout>
        </LinearLayout>
        <include layout="@layout/floating_toolbar_layout"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <com.samsung.android.gallery.widget.effects.DimView android:id="@+id/dim_view" android:background="@color/search_blur_dim_color" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
</FrameLayout>
