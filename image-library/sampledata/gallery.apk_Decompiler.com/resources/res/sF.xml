<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="left|center_vertical|center_horizontal|center|start" android:orientation="vertical" android:id="@+id/moreinfo_location" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
    <TextView android:textSize="13dp" android:ellipsize="end" android:id="@+id/moreinfo_item_title" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/moreinfo_location_title_bottom_margin" android:text="@string/location" android:maxLines="2" style="@style/MoreInfoDetailsHeaderTextStyleV3"/>
    <FrameLayout android:id="@+id/moreinfo_map_frame" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/moreinfo_map_container" android:background="@drawable/details_map_bg" android:focusable="true" android:visibility="gone" android:layout_width="match_parent" android:layout_height="@dimen/moreinfo_oneui5x_item_map_height" android:contentDescription="@string/location" android:clipToOutline="true">
            <ImageView android:id="@+id/mapImage" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:clipToOutline="true"/>
            <include android:layout_gravity="center" android:id="@+id/map_view_marker_holder" android:visibility="invisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@null" layout="@layout/map_view_popup_layout"/>
