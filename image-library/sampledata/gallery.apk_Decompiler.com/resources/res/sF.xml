        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/moreinfo_location_poi_layout" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/moreinfo_location_poi_layout_top_margin" android:layout_marginStart="@dimen/moreinfo_location_poi_layout_start_margin">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/gallery_ic_detail_view_location_solid" android:tint="@color/details_poi_color" android:layout_marginEnd="1dp"/>
            <com.samsung.android.gallery.widget.UtlTextView android:textSize="@dimen/moreinfo_location_poi_text_size" android:textColor="@color/details_poi_color" android:id="@+id/moreinfo_location_poi_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:lineSpacingExtra="0.01sp" app:resizableTextSize="@dimen/moreinfo_location_poi_text_size" style="@style/OneUiRobotoSemiBold"/>
