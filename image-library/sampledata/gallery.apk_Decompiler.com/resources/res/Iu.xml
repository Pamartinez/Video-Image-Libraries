<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="@dimen/bottom_search_toolbar_floating_suggestion_item_margin_end" android:layout_marginVertical="@dimen/bottom_search_toolbar_floating_suggestion_item_gap">
    <LinearLayout android:layout_gravity="center_vertical" android:orientation="horizontal" android:id="@+id/floating_suggestion_container" android:background="@drawable/search_floating_suggestion_item_background" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingHorizontal="@dimen/bottom_search_toolbar_floating_suggestion_item_padding_horizontal">
        <ImageView android:layout_gravity="center_vertical" android:id="@+id/floating_suggestion_icon" android:layout_width="@dimen/search_recommend_item_icon_size" android:layout_height="@dimen/search_recommend_item_icon_size" android:tint="@color/search_recommend_icon_color" android:contentDescription="@null" android:layout_marginEnd="@dimen/search_recommend_item_text_margin_end"/>
        <com.samsung.android.gallery.widget.UtlTextView android:textSize="14sp" android:textColor="@color/search_floating_suggestion_item_text_color" android:ellipsize="end" android:layout_gravity="center_vertical" android:id="@+id/floating_suggestion_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="recommendation title" android:maxLines="1" android:paddingVertical="@dimen/search_recommend_item_text_padding_vertical" app:resizableTextSize="14sp" style="@style/OneUiRobotoMedium"/>
    </LinearLayout>
