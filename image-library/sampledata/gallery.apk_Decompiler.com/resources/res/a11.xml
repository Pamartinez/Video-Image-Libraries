                <com.samsung.android.gallery.widget.NoItemView android:id="@+id/no_item_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" app:description="@string/empty_set_description_picture_no_item_vi" app:label="@string/empty_set_description_no_items"/>
            </LinearLayout>
        </RelativeLayout>
        <include android:layout_width="match_parent" android:layout_height="match_parent" layout="@layout/gallery_list_view"/>
    </LinearLayout>
    <include layout="@layout/floating_toolbar_layout"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
