<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:customPreference="appbar_stories" app:expanded="true" style="@style/AppBarLayoutStyle">
        <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" style="@style/CollapsingToolBarStyle">
            <include layout="@layout/floating_toolbar_dummy_view"/>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
    <LinearLayout android:orientation="vertical" android:focusable="false" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <com.samsung.android.gallery.widget.listview.PinchParentLayout android:focusable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent">
                <ViewStub android:id="@+id/empty_view" android:layout="@layout/fragment_stories_pinch_emptyview_stub" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <com.samsung.android.gallery.widget.listview.GallerySwipeView android:layout_gravity="center_horizontal" android:id="@+id/my_recycler_view" android:focusable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <FrameLayout android:id="@+id/fake_view_layout" android:visibility="gone" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent"/>
            </com.samsung.android.gallery.widget.listview.PinchParentLayout>
        </FrameLayout>
    </LinearLayout>
    <include layout="@layout/floating_toolbar_layout"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
