<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:id="@+id/bottom_deco_container" android:visibility="invisible" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
        <RelativeLayout android:id="@+id/bottom_control" android:layout_width="match_parent" android:layout_height="@dimen/story_highlight_deco_duration_min_height" android:layout_marginBottom="@dimen/story_highlight_deco_vertical_gap" android:paddingHorizontal="@dimen/story_highlight_bottom_control_side_padding">
            <ViewStub android:id="@+id/filter_icon_stub" android:layout="@layout/story_filter_icon_layout" android:inflatedId="@+id/filter_icon" android:layout_width="@dimen/story_highlight_deco_duration_min_height" android:layout_height="match_parent"/>
            <ViewStub android:id="@+id/bgm_icon_stub" android:layout="@layout/story_bgm_picker_icon" android:inflatedId="@+id/bgm_icon" android:layout_width="@dimen/story_highlight_deco_duration_min_height" android:layout_height="match_parent"/>
            <LinearLayout android:gravity="center_vertical" android:id="@+id/play_switch_layout" android:background="@drawable/story_highlight_deco_background" android:layout_width="wrap_content" android:layout_height="match_parent" android:minHeight="@dimen/story_highlight_deco_duration_min_height" android:layout_centerInParent="true" android:paddingStart="@dimen/story_highlight_deco_duration_start_margin" android:paddingEnd="@dimen/story_highlight_deco_duration_end_margin">
                <ImageView android:id="@+id/play_switch_icon" android:layout_width="@dimen/story_highlight_deco_play_icon_size" android:layout_height="@dimen/story_highlight_deco_play_icon_size" android:foreground="@drawable/recoil_ripple_oval" android:src="@drawable/gallery_ic_detail_pause" android:tint="@color/white_color" android:contentDescription="@string/pause_video" android:layout_marginEnd="@dimen/story_highlight_deco_play_icon_end_margin" android:stateListAnimator="?attr/seslSmallTouchAnimator"/>
                <TextView android:textSize="@dimen/story_highlight_deco_play_duration_text_size" android:textColor="@color/white" android:id="@+id/play_duration" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/OneUiRobotoRegular"/>
            </LinearLayout>
            <ViewStub android:id="@+id/play_audio_icon_stub" android:layout="@layout/story_play_audio_icon_layout" android:inflatedId="@+id/play_audio_icon" android:layout_width="@dimen/story_highlight_deco_duration_min_height" android:layout_height="match_parent" android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ViewStub android:id="@+id/film_strip_layout_stub" android:layout="@layout/stories_filmstrip_layout" android:inflatedId="@+id/film_strip_layout" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</RelativeLayout>
