<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_item_view" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/search_cluster_results_item_padding_bottom">
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/thumbnail_container" android:layout_width="@dimen/search_cluster_results_album_type_item_size" android:layout_height="@dimen/search_cluster_results_album_type_item_size">
            <ImageView android:id="@+id/thumbnail" android:contentDescription="@null" style="@style/ThumbnailStyle"/>
            <View android:id="@+id/thumbnail_preview_background" android:background="@android:color/white" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <FrameLayout android:id="@+id/thumbnail_preview_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <ImageView android:layout_gravity="bottom|right|center_vertical|center_horizontal|center|end" android:id="@+id/text_extraction_button_icon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:src="@drawable/gallery_ic_search_cluster_ocr" android:layout_marginEnd="10dp"/>
        </FrameLayout>
        <include layout="@layout/recycler_item_search_result_title_layout"/>
    </LinearLayout>
</FrameLayout>
