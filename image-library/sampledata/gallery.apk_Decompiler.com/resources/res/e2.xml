<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/recycler_view_item" android:focusable="true" android:clickable="true" android:layout_width="@dimen/stories_filter_item_size" android:layout_height="@dimen/stories_filter_item_size">
    <FrameLayout android:id="@+id/thumbnail_container" android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/thumbnail" android:background="@color/thumbnail_icon_background" android:contentDescription="@null" style="@style/ThumbnailStyle"/>
        <View android:id="@+id/gradient_view" android:background="@drawable/stories_pin_bottom_gradient" android:layout_width="match_parent" android:layout_height="match_parent"/>
    </FrameLayout>
    <LinearLayout android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:id="@+id/title_container" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
        <com.samsung.android.gallery.widget.GalleryTextView android:textSize="12sp" android:textColor="#ffffff" android:ellipsize="end" android:gravity="center" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="2" android:textIsSelectable="false" style="@style/OneUiRobotoSemiBold"/>
    </LinearLayout>
</FrameLayout>
