<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/recycler_item_view" android:nextFocusDown="@+id/highlight_play" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content">
