<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center_horizontal" android:orientation="vertical" android:paddingBottom="@dimen/stories_view_item_gap" android:nextFocusDown="@+id/highlight_play" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content">
    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="0dp" android:layout_marginEnd="0dp">
        <ImageView android:id="@+id/thumbnail" android:layout_width="match_parent" android:layout_height="@dimen/stories_view_thumbnail_height" android:contentDescription="@null"/>
        <View android:id="@+id/gradient_view" android:background="@drawable/gallery_gradient_story" android:layout_width="match_parent" android:layout_height="@dimen/stories_view_thumbnail_height"/>
        <ViewStub android:id="@+id/checkboxViewStub" android:layout="@layout/thumbnail_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/stories_view_checkbox_margin_top" android:layout_marginStart="@dimen/stories_view_checkbox_margin_start"/>
        <ImageButton android:layout_gravity="bottom|right|center_vertical|center_horizontal|center|end" android:id="@+id/highlight_play" android:background="@drawable/gallery_ic_cover_video" android:visibility="gone" android:layout_width="@dimen/stories_view_play_icon_size" android:layout_height="@dimen/stories_view_play_icon_size" android:layout_marginBottom="@dimen/stories_view_play_icon_bottom_margin" android:contentDescription="@string/play_video" android:layout_marginEnd="@dimen/stories_view_play_icon_end_margin"/>
        <TextView android:textSize="@dimen/stories_view_new_mark_text_size" android:layout_gravity="top|right|center_vertical|center_horizontal|center|end" android:id="@+id/newLabel" android:visibility="gone" android:layout_marginTop="@dimen/stories_view_new_mark_top_margin" android:text="@string/new_label" android:textAllCaps="true" android:layout_marginEnd="@dimen/stories_view_new_mark_end_margin" style="@style/StoryNewBadgeStyle"/>
        <LinearLayout android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/stories_view_duration_margin_bottom" android:layout_marginStart="@dimen/stories_view_title_side_margin" android:layout_marginEnd="@dimen/stories_view_title_side_margin">
            <TextView android:textSize="@dimen/stories_view_item_title_text_size" android:textColor="@color/stories_title_color" android:ellipsize="end" android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/stories_view_title_duration_gap" android:maxLines="1" android:textIsSelectable="false" android:textAlignment="center" style="@style/OneUiRobotoLight"/>
            <TextView android:textSize="@dimen/stories_view_item_duration_text_size" android:textColor="@color/stories_title_color" android:ellipsize="end" android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:id="@+id/duration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:textIsSelectable="false" android:textAlignment="center" style="@style/OneUiRobotoRegular"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
