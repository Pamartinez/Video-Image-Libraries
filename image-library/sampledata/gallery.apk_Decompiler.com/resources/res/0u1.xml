<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="horizontal" android:id="@+id/search_bar" android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:textAppearance="?android:attr/textAppearanceMedium" android:textColor="?android:attr/textColorPrimary" android:gravity="center_vertical" android:id="@+id/search_badge" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginBottom="2dp" android:drawablePadding="0dp"/>
    <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_button" android:focusable="true" android:layout_width="wrap_content" android:layout_height="match_parent" android:contentDescription="@string/sesl_searchview_description_search" style="?attr/actionButtonStyle"/>
    <LinearLayout android:layout_gravity="center_vertical" android:orientation="horizontal" android:id="@+id/search_edit_frame" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="locale">
        <FrameLayout android:layout_gravity="center_vertical" android:id="@+id/search_plate_frame" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="@dimen/sesl_search_plate_height" android:layout_marginTop="@dimen/sesl_search_plate_margin" android:layout_marginBottom="@dimen/sesl_search_plate_margin" android:layout_marginStart="@dimen/sesl_search_margin_start" android:layout_marginEnd="@dimen/sesl_search_margin_end">
            <LinearLayout android:gravity="center_vertical" android:layout_gravity="center_vertical" android:orientation="horizontal" android:id="@+id/search_plate" android:layout_width="match_parent" android:layout_height="match_parent" android:weightSum="1" android:paddingStart="@dimen/sesl_search_plate_padding_start" android:paddingEnd="@dimen/sesl_search_plate_padding_end">
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_back_btn" android:focusable="true" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:src="@drawable/sesl_ic_search_back" android:scaleType="centerInside" android:contentDescription="@string/sesl_action_bar_up_description" style="?attr/actionButtonStyle"/>
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_mag_icon" android:focusable="true" android:visibility="gone" android:layout_width="@dimen/sesl_search_view_icon_width" android:layout_height="@dimen/sesl_search_view_icon_height" android:scaleType="center" android:tint="@color/sesl_search_view_mag_icon_color" android:contentDescription="@string/sesl_searchview_description_search" android:layout_marginEnd="2dp" style="?attr/actionButtonStyle"/>
                <view android:textSize="@dimen/sesl_search_view_search_text_size" android:ellipsize="end" android:layout_gravity="center_vertical" android:id="@+id/search_src_text" android:background="@null" android:layout_width="0dp" android:layout_height="wrap_content" android:minWidth="@dimen/sesl_search_view_text_min_width" android:minHeight="@dimen/sesl_search_view_text_min_height" android:maxLines="1" android:maxLength="1000" android:layout_weight="1" android:inputType="none|text|textAutoComplete|textNoSuggestions" android:dropDownAnchor="@+id/search_plate" android:imeOptions="actionSearch" android:dropDownHeight="wrap_content" android:dropDownHorizontalOffset="0dp" android:dropDownVerticalOffset="1dp" android:nextFocusForward="@+id/search_back_btn" android:paddingStart="4dp" app:emojiCompatEnabled="false" class="androidx.appcompat.widget.SearchView$SearchAutoComplete"/>
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_close_btn" android:focusable="true" android:layout_width="wrap_content" android:layout_height="match_parent" android:contentDescription="@string/sesl_searchview_description_clear" android:paddingStart="6dp" android:paddingEnd="6dp" style="?attr/actionButtonStyle"/>
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_go_btn" android:focusable="true" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:contentDescription="@string/sesl_searchview_description_submit" android:paddingStart="6dp" android:paddingEnd="6dp" style="?attr/actionButtonStyle"/>
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_voice_btn" android:focusable="true" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:contentDescription="@string/sesl_searchview_description_voice" android:paddingStart="6dp" android:paddingEnd="6dp" style="?attr/actionButtonStyle"/>
                <ImageView android:layout_gravity="center_vertical" android:id="@+id/search_more_btn" android:focusable="true" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:src="@drawable/sesl_ic_search_more" android:contentDescription="@string/sesl_action_menu_overflow_description" android:paddingStart="6dp" android:paddingEnd="6dp" style="?attr/actionButtonStyle"/>
                <Space android:layout_width="4dp" android:layout_height="match_parent"/>
                <LinearLayout android:orientation="horizontal" android:id="@+id/submit_area" android:layout_width="wrap_content" android:layout_height="match_parent"/>
            </LinearLayout>
            <View android:id="@+id/search_plate_stroke_overlay" android:background="@drawable/sesl_search_view_bottom_stroke_overlay" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:importantForAccessibility="no"/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
