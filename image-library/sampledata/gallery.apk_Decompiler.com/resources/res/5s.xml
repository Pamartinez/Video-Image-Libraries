<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/video_ctrl_container" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageButton android:id="@+id/video_play_button" android:background="@drawable/gallery_detail_play_bg" android:padding="4dp" android:layout_width="@dimen/video_ctrl_play_button_size" android:layout_height="@dimen/video_ctrl_play_button_size" android:foreground="@drawable/viewer_recoil_button_ripple" android:src="@drawable/gallery_ic_detail_play" android:scaleType="fitCenter" android:adjustViewBounds="true" android:stateListAnimator="?attr/seslSmallTouchAnimator"/>
    <RelativeLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="@dimen/video_ctrl_size">
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/video_strip" android:focusable="false" android:clickable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="@dimen/video_ctrl_thumbnail_size" android:layout_centerVertical="true" android:overScrollMode="never" android:layout_marginStart="@dimen/video_ctrl_seekbar_gap"/>
        <View android:id="@+id/video_seekbar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <View android:id="@+id/video_seek_handler" android:background="@drawable/video_ctrl_seekbar_thumb" android:focusable="false" android:clickable="false" android:layout_width="@dimen/video_ctrl_seekbar_handler_size" android:layout_height="match_parent" android:layout_marginStart="@dimen/video_ctrl_seekbar_gap" android:elevation="1dp"/>
    </RelativeLayout>
</LinearLayout>
