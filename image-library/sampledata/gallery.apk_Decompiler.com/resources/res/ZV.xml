            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/start_date_area" android:background="@drawable/recoil_button_ripple" android:clickable="true" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:stateListAnimator="?attr/seslSmallTouchAnimator" android:paddingHorizontal="@dimen/range_date_picker_date_area_padding_horizontal" android:paddingVertical="@dimen/range_date_picker_date_area_padding_vertical">
