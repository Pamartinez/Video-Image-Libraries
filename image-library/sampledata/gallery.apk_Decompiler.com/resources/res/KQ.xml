<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/main_layout" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <androidx.coordinatorlayout.widget.CoordinatorLayout android:id="@+id/coordinator_layout" android:layout_width="match_parent" android:layout_height="match_parent">
            <com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout android:id="@+id/appbar" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="0dp" app:customPreference="appbar_stories" app:expanded="true" style="@style/AppBarLayoutStyle">
                <com.google.android.material.appbar.CollapsingToolbarLayout android:id="@+id/toolbar_layout" style="@style/CollapsingToolBarStyle">
                    <com.samsung.android.gallery.widget.toolbar.GalleryToolbar android:layout_gravity="bottom" android:id="@+id/toolbar" app:layout_collapseMode="1" style="@style/ToolbarStyle"/>
                </com.google.android.material.appbar.CollapsingToolbarLayout>
            </com.samsung.android.gallery.widget.toolbar.GalleryAppBarLayout>
            <RelativeLayout android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
                <ViewStub android:id="@+id/empty_view" android:layout="@layout/fragment_stories_emptyview_stub" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <com.samsung.android.gallery.widget.listview.GalleryListView android:layout_gravity="center_horizontal" android:id="@+id/my_recycler_view" android:focusable="false" android:clipChildren="false" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent"/>
            </RelativeLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </FrameLayout>
</FrameLayout>
