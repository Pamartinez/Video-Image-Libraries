<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/group_item_panel" android:layoutAnimation="@anim/layout_anim_group_panel" android:layout_width="wrap_content" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:id="@+id/group_panel_content_container" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/group_panel_header_container" android:background="@drawable/single_taken_bottom_sheet_layout_bg" android:paddingTop="@dimen/single_taken_bottom_sheet_layout_bg_padding_top" android:visibility="visible" android:clickable="true" android:layout_width="match_parent" android:layout_height="@dimen/group_panel_header_height" android:contentDescription="@string/collapsed">
            <LinearLayout android:gravity="center_vertical" android:layout_gravity="left|center_vertical|center_horizontal|center|start" android:id="@+id/group_panel_title_container" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="@dimen/single_taken_count_layout_margin_start" android:paddingEnd="@dimen/single_taken_select_text_side_padding">
                <ImageView android:id="@+id/header_icon" android:layout_width="@dimen/single_taken_count_icon_size" android:layout_height="@dimen/single_taken_count_icon_size" android:src="@drawable/gallery_ic_search_single_take" android:scaleType="fitCenter" android:tint="@color/single_taken_text_color" android:contentDescription="@null" android:layout_marginEnd="@dimen/single_taken_count_view_gap"/>
                <com.samsung.android.gallery.widget.StrokeTextView android:textSize="@dimen/single_taken_count_text_size" android:textColor="@color/single_taken_text_color" android:ellipsize="end" android:id="@+id/header_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="@dimen/single_taken_header_text_max_width" android:singleLine="true" android:layout_marginEnd="@dimen/single_taken_count_view_gap" app:textStroke="true" app:textStrokeColor="@color/single_taken_count_text_stroke_color" app:textStrokeWidth="@dimen/single_taken_text_stroke_width" style="@style/OneUiRobotoRegular"/>
                <com.samsung.android.gallery.widget.StrokeTextView android:textSize="@dimen/single_taken_count_text_size" android:textColor="@color/single_taken_count_color" android:id="@+id/group_panel_count_view" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" app:textStroke="true" app:textStrokeColor="@color/single_taken_count_text_stroke_color" app:textStrokeWidth="@dimen/single_taken_text_stroke_width" style="@style/OneUiRobotoRegular"/>
            </LinearLayout>
            <ImageView android:layout_gravity="center" android:id="@+id/handle_icon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/detail_view_single_take_handler" android:rotation="180"/>
            <FrameLayout android:gravity="center" android:layout_gravity="right|center_vertical|center_horizontal|center|end" android:id="@+id/cancel_button" android:background="@drawable/group_panel_cancel_icon_background" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@string/cancel" android:layout_marginEnd="@dimen/single_taken_count_layout_margin_start">
                <ImageView android:layout_gravity="center" android:clickable="false" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_cancel_close_xmark" android:tint="@color/single_taken_shot_mode_text_color"/>
            </FrameLayout>
        </FrameLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/list_container" android:background="@color/single_taken_list_bg_color" android:paddingLeft="@dimen/group_panel_list_horizontal_padding" android:paddingRight="@dimen/group_panel_list_horizontal_padding" android:visibility="visible" android:layout_width="match_parent" android:layout_height="match_parent">
            <com.samsung.android.gallery.widget.listview.SingleTakenListView android:id="@+id/single_taken_list_view" android:focusable="false" android:layout_width="match_parent" android:layout_height="wrap_content" app:enableGoToTop="false"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <RelativeLayout android:gravity="center_horizontal" android:id="@+id/fast_option_view_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
        <com.samsung.android.gallery.widget.fastoption2.FastOptionView android:id="@+id/fast_option_view" android:background="@drawable/fast_option_background_single_take" android:visibility="gone" android:layout_width="match_parent" android:layout_height="@dimen/fast_menu_imageview_height"/>
    </RelativeLayout>
</RelativeLayout>
