<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/private_album_unlock_background_color" android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:id="@+id/unlock_screen_container" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="@dimen/unlock_container_top_margin" android:layout_centerHorizontal="true">
        <ImageView android:layout_gravity="center" android:layout_width="@dimen/private_album_unlock_guide_image_size" android:layout_height="@dimen/private_album_unlock_guide_image_size" android:layout_marginTop="@dimen/private_album_unlock_guide_image_margin" android:layout_marginBottom="@dimen/private_album_unlock_guide_image_margin" android:src="@drawable/ic_private_album_rectangle_lock"/>
        <RelativeLayout android:layout_gravity="center_horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerHorizontal="true">
            <TextView android:textSize="30sp" android:textColor="@color/private_album_unlock_title_text_color" android:id="@+id/unlock_title_text_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/private_album_header" android:layout_centerHorizontal="true" android:layout_marginStart="@dimen/unlock_text_horizontal_margin" android:layout_marginEnd="@dimen/unlock_text_horizontal_margin" style="@style/OneUiRobotoBold"/>
            <TextView android:textSize="17sp" android:textColor="@color/private_album_unlock_title_text_color" android:gravity="center" android:id="@+id/unlock_description_text_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/private_album_empty_set_description_no_item" android:layout_below="@+id/unlock_title_text_view" android:layout_centerHorizontal="true" android:layout_marginStart="@dimen/unlock_text_horizontal_margin" android:layout_marginEnd="@dimen/unlock_text_horizontal_margin" style="@style/OneUiRobotoRegular"/>
        </RelativeLayout>
        <LinearLayout android:gravity="bottom" android:layout_gravity="bottom|center_vertical|center_horizontal|center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
            <RelativeLayout android:layout_gravity="center" android:id="@+id/lock_icon_layout" android:background="@drawable/unlock_icon_bg" android:clickable="true" android:layout_width="68dp" android:layout_height="68dp" android:layout_marginBottom="90dp" android:contentDescription="@string/speak_lock_icon">
                <ImageView android:id="@+id/lock_icon" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/gallery_ic_detail_lock_touch" android:shadowColor="#33000000" android:shadowDx="0" android:shadowDy="0.5" android:shadowRadius="0.5" android:layout_centerInParent="true"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
