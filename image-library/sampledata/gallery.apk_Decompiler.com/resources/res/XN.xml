<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="left|center_vertical|center_horizontal|center|start" android:layout_gravity="top" android:orientation="vertical" android:id="@+id/title_area" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="22dp">
    <LinearLayout android:gravity="bottom" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/story_collage_page_title_text_size" android:textColor="#000000" android:ellipsize="marquee" android:gravity="bottom" android:id="@+id/title" android:background="@drawable/recoil_ripple_rect" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text=" " android:maxLines="1" style="@style/OneUiRobotoSemiBold"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <EditText android:textSize="23dp" android:textColor="#000000" android:gravity="start" android:id="@+id/title_edit" android:background="@null" android:padding="0dp" android:focusable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:minWidth="3dp" android:maxLines="1" android:scrollHorizontally="true" android:inputType="textCapSentences" android:privateImeOptions="inputType=filename" android:imeOptions="actionUnspecified|actionGo|actionSend|actionDone|flagNoExtractUi" android:textIsSelectable="true" android:textCursorDrawable="@drawable/edittext_cursor_black" android:labelFor="@+id/itemname_edit" android:backgroundTint="@color/white_color" app:layout_constraintHorizontal_chainStyle="2" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintWidth_default="1" app:resizableTextSize="@dimen/story_collage_page_title_text_size"/>
            <View android:background="@color/text_edit_indicator_black" android:layout_width="match_parent" android:layout_height="2dp" android:layout_marginTop="3dp" android:paddingStart="1dp" android:paddingEnd="1dp" app:layout_constraintEnd_toEndOf="@+id/title_edit" app:layout_constraintStart_toStartOf="@+id/title_edit" app:layout_constraintTop_toBottomOf="@+id/title_edit"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <TextView android:textSize="9dp" android:textColor="#515151" android:ellipsize="marquee" android:id="@+id/subtitle" android:paddingTop="3dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text=" " android:maxLines="1" style="@style/OneUiRobotoLight"/>
</LinearLayout>
