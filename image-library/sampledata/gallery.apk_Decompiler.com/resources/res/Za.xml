        <View android:id="@+id/touch_layout" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true" layout="@layout/recap_bottom_decor_layout"/>
