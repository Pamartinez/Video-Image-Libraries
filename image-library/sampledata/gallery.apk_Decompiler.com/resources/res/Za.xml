<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:appfn="http://schemas.android.com/apk/androidx.appfunctions" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/black" android:focusable="false" android:fitsSystemWindows="true" android:clickable="false" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:focusable="false" android:layout_width="match_parent" android:layout_height="match_parent">
        <com.samsung.android.gallery.widget.videoview.mediaplayer.MediaPlayerViewCompat android:id="@+id/video_view" android:visibility="invisible" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_centerInParent="true" app:fit_content="true" app:player_feature="true"/>
